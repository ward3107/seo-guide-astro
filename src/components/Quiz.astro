---
/**
 * Quiz Component
 *
 * A reusable quiz component with multiple choice questions
 *
 * @param id - Unique identifier for the quiz
 * @param title - Quiz title
 * @param questions - Array of question objects with q, options, correct, explanation
 */
interface Question {
  q: string;
  options: string[];
  correct: string;
  explanation?: string;
}

interface ShuffledQuestion {
  q: string;
  options: string[];
  correct: string;
  explanation?: string;
}

interface Props {
  id: string;
  title: string;
  questions: Question[];
}

const { id, title, questions } = Astro.props;

// Fisher-Yates shuffle algorithm for arrays
function shuffleArray<T>(array: T[]): T[] {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

// Shuffle options for each question while tracking the correct answer
const shuffledQuestions: ShuffledQuestion[] = questions.map(question => {
  // Create array of option objects with their original letters
  const originalOptions = question.options.map((opt, idx) => ({
    text: opt,
    originalLetter: String.fromCharCode(97 + idx) // a, b, c, d...
  }));

  // Shuffle the options
  const shuffledOptions = shuffleArray(originalOptions);

  // Find where the correct answer ended up
  const originalCorrectIndex = question.correct.charCodeAt(0) - 97; // 0 for 'a', 1 for 'b', etc.
  const correctText = question.options[originalCorrectIndex];
  const newCorrectIndex = shuffledOptions.findIndex(opt => opt.text === correctText);
  const newCorrectLetter = String.fromCharCode(97 + newCorrectIndex); // new position letter

  return {
    q: question.q,
    options: shuffledOptions.map(opt => opt.text),
    correct: newCorrectLetter,
    explanation: question.explanation
  };
});
---

<div class="quiz-container" id={`quiz-${id}`}>
  <h3>{title}</h3>
  <form class="quiz-form" data-quiz-id={id}>
    {shuffledQuestions.map((question, index) => (
      <div class="question" data-question={index + 1}>
        <p class="question-text">
          <strong>{index + 1}. {question.q}</strong>
        </p>
        <div class="options">
          {question.options.map((option, optIndex) => {
            const letter = String.fromCharCode(97 + optIndex); // a, b, c, d...
            const letterDisplay = String.fromCharCode(65 + optIndex); // A, B, C, D...
            return (
              <label class="option-label" data-letter={letterDisplay}>
                <input
                  type="radio"
                  name={`${id}-q${index + 1}`}
                  value={letter}
                  data-correct={question.correct}
                />
                <span class="option-text">{option}</span>
              </label>
            );
          })}
        </div>
        {question.explanation && (
          <p class="explanation" data-explanation-for={`${id}-q${index + 1}`}>
            <strong>💡 Explanation:</strong> {question.explanation}
          </p>
        )}
      </div>
    ))}
    <button type="submit" class="quiz-submit">Submit Quiz</button>
  </form>
  <div class="quiz-result" id={`result-${id}`}></div>
</div>

<style>
  .quiz-container {
    background: var(--gradient-card);
    padding: 30px;
    border-radius: 20px;
    margin: 30px 0;
  }

  .quiz-container h3 {
    color: var(--color-brand-primary);
    margin-bottom: 25px;
    font-size: 1.5em;
  }

  .question {
    margin-bottom: 30px;
    padding: 25px;
    background: var(--color-surface);
    border-radius: 20px;
    border: 2px solid var(--color-border);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    position: relative;
    overflow: hidden;
  }

  .question::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  }

  .question:last-child {
    margin-bottom: 0;
  }

  .question-text {
    margin-bottom: 20px;
    color: var(--color-text);
  }

  .question-text strong {
    display: inline-block;
    font-size: 1.2em;
    color: var(--color-text);
    margin-bottom: 5px;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .option-label {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: #fafbfc;
    border-radius: 14px;
    cursor: pointer;
    transition: all 0.25s ease;
    border: 2px solid var(--color-border);
    position: relative;
  }

  .option-label::before {
    content: attr(data-letter);
    background: #e8edf5;
    color: #555;
    width: 36px;
    height: 36px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9em;
    font-weight: 700;
    flex-shrink: 0;
    transition: all 0.25s ease;
  }

  .option-label:hover {
    background: #f0f4ff;
    border-color: var(--color-brand-primary);
    transform: translateX(4px);
    box-shadow: 0 3px 12px rgba(102, 126, 234, 0.12);
  }

  .option-label.selected {
    border-color: var(--color-brand-primary);
    background: #f0f4ff;
  }

  .option-label.selected::before {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .option-label.correct::before {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
    transform: scale(1.05);
  }

  .option-label.incorrect::before {
    background: #dc3545;
    color: white;
  }

  .option-label.correct {
    border-color: #28a745;
    background: #d4edda;
    box-shadow: 0 3px 12px rgba(40, 167, 69, 0.15);
  }

  .option-label.incorrect {
    border-color: #dc3545;
    background: #f8d7da;
  }

  .option-label input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .option-text {
    flex: 1;
    color: var(--color-text-secondary);
    font-size: 1.05em;
  }

  .explanation {
    display: none;
    margin-top: 12px;
    padding: 12px;
    background: #e3f2fd;
    border-left: 4px solid #2196f3;
    border-radius: 6px;
    font-size: 0.9em;
  }

  .explanation.show {
    display: block;
  }

  .quiz-submit {
    background: var(--color-brand-gradient);
    color: white;
    border: none;
    padding: 15px 40px;
    border-radius: 25px;
    font-size: 1.1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 20px;
  }

  .quiz-submit:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .quiz-result {
    margin-top: 20px;
    padding: 20px;
    border-radius: 10px;
    text-align: center;
    font-weight: 600;
    display: none;
  }

  .quiz-result.show {
    display: block;
  }

  .quiz-result.pass {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    color: #155724;
    border: 2px solid var(--color-success);
  }

  .quiz-result.fail {
    background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
    color: #721c24;
    border: 2px solid var(--color-error);
  }

  .quiz-result .score-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin: 0 auto 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2em;
  }

  .quiz-result.pass .score-circle {
    background: white;
    color: var(--color-success);
  }

  .quiz-result.fail .score-circle {
    background: white;
    color: var(--color-error);
  }

  /* Dark mode */
  :global(body.dark-mode) .quiz-container,
  :global([data-theme="dark"]) .quiz-container {
    background: linear-gradient(135deg, #2a2a4a 0%, #1a1a2e 100%);
  }

  :global(body.dark-mode) .quiz-container h3,
  :global([data-theme="dark"]) .quiz-container h3 {
    color: var(--color-heading-primary, #a8dadc);
  }

  :global(body.dark-mode) .question-text,
  :global([data-theme="dark"]) .question-text {
    color: var(--color-text);
  }

  :global(body.dark-mode) .option-label,
  :global([data-theme="dark"]) .option-label {
    background: var(--color-surface-elevated);
    color: var(--color-text-secondary);
  }

  :global(body.dark-mode) .option-label:hover,
  :global([data-theme="dark"]) .option-label:hover {
    background: var(--color-border);
  }

  :global(body.dark-mode) .explanation,
  :global([data-theme="dark"]) .explanation {
    background: #16213e;
    border-left-color: var(--color-heading-primary, #a8dadc);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .quiz-container {
      padding: 20px;
    }
  }
</style>

<script>
  // Quiz functionality - scoped to each quiz instance
  document.addEventListener('DOMContentLoaded', () => {
    const quizContainer = document.getElementById(`quiz-${Astro.props.id}`);
    if (!quizContainer) return;

    const form = quizContainer.querySelector('.quiz-form');
    const resultDiv = quizContainer.querySelector('.quiz-result');
    const questions = quizContainer.querySelectorAll('.question');

    if (!form || !resultDiv) return;

    // Track selected options
    form.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target && target.type === 'radio') {
        const label = target.closest('.option-label');
        if (label) {
          label.closest('.options')?.querySelectorAll('.option-label').forEach(l => {
            l.classList.remove('selected');
          });
          label.classList.add('selected');
        }
      }
    });

    // Handle form submission
    form.addEventListener('submit', (e: Event) => {
      e.preventDefault();

      let score = 0;
      let total = questions.length;
      const passingScore = Astro.props.passingScore;
      const quizId = Astro.props.id;

      questions.forEach((question) => {
        const selected = question.querySelector('input[type="radio"]:checked') as HTMLInputElement;
        const correctInput = question.querySelector('input[type="radio"]') as HTMLInputElement;
        const correct = correctInput?.dataset.correct;
        const explanation = question.querySelector('.explanation');

        // Reset classes
        question.querySelectorAll('.option-label').forEach(label => {
          label.classList.remove('correct', 'incorrect');
        });

        if (selected && correct) {
          if (selected.value === correct) {
            score++;
            selected.closest('.option-label')?.classList.add('correct');
          } else {
            selected.closest('.option-label')?.classList.add('incorrect');
            // Highlight correct answer
            question.querySelector(`input[value="${correct}"]`)?.closest('.option-label')?.classList.add('correct');
          }
        }

        // Show explanation
        if (explanation) {
          explanation.classList.add('show');
        }
      });

      const percentage = Math.round((score / total) * 100);
      const passed = percentage >= passingScore;

      resultDiv.innerHTML = `
        <div class="score-circle">${percentage}%</div>
        <p>${passed ? '🎉 Congratulations!' : 'Keep practicing!'}</p>
        <p>You scored ${score} out of ${total} (${percentage}%)</p>
        <p>${passed ? 'You passed this quiz!' : `You need ${passingScore}% to pass. Try again!`}</p>
      `;

      resultDiv.className = `quiz-result show ${passed ? 'pass' : 'fail'}`;

      // Save progress to localStorage
      saveQuizProgress(quizId, percentage);

      // Move focus to result for accessibility
      (resultDiv as HTMLElement).setAttribute('tabindex', '-1');
      (resultDiv as HTMLElement).focus();

      // Scroll to result
      resultDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });

  // Save quiz progress to localStorage
  function saveQuizProgress(quizId: string, score: number) {
    const storageKey = 'seoCourseProgress';
    const stored = localStorage.getItem(storageKey);
    const progress = stored ? JSON.parse(stored) : {
      levels: {
        level1: { completed: false, progress: 0 },
        level2: { completed: false, progress: 0 },
        level3: { completed: false, progress: 0 },
        level4: { completed: false, progress: 0 }
      },
      quizzes: {
        quickQuiz: { taken: 0, bestScore: 0 },
        timedChallenge: { taken: 0, bestScore: 0 },
        practiceMode: { taken: 0, bestScore: 0 },
        finalTest: { taken: 0, bestScore: 0 }
      },
      achievements: []
    };

    // Map quiz IDs to progress keys
    const quizKeyMap: Record<string, 'quickQuiz' | 'timedChallenge' | 'practiceMode' | 'finalTest'> = {
      'final-test': 'finalTest',
      'quick-quiz': 'quickQuiz',
      'timed-challenge': 'timedChallenge',
      'practice-mode': 'practiceMode'
    };

    const progressKey = quizKeyMap[quizId];
    if (progressKey && progress.quizzes[progressKey]) {
      progress.quizzes[progressKey].taken++;
      if (score > progress.quizzes[progressKey].bestScore) {
        progress.quizzes[progressKey].bestScore = score;
      }
    }

    localStorage.setItem(storageKey, JSON.stringify(progress));
  }
</script>
