---
/**
 * Quiz Component
 *
 * A reusable quiz component with multiple choice questions
 *
 * @param id - Unique identifier for the quiz
 * @param title - Quiz title
 * @param questions - Array of question objects with q, options, correct, explanation
 */
interface Question {
  q: string;
  options: string[];
  correct: string;
  explanation?: string;
}

interface Props {
  id: string;
  title: string;
  questions: Question[];
  passingScore?: number;
}

const { id, title, questions, passingScore = 75 } = Astro.props;
---

<div class="quiz-container" id={`quiz-${id}`}>
  <h3>{title}</h3>
  <form class="quiz-form" data-quiz-id={id}>
    {questions.map((question, index) => (
      <div class="question" data-question={index + 1}>
        <p class="question-text">
          <strong>{index + 1}. {question.q}</strong>
        </p>
        <div class="options">
          {question.options.map((option, optIndex) => {
            const letter = String.fromCharCode(97 + optIndex); // a, b, c, d...
            return (
              <label class="option-label">
                <input
                  type="radio"
                  name={`${id}-q${index + 1}`}
                  value={letter}
                  data-correct={question.correct}
                />
                <span class="option-text">{option}</span>
              </label>
            );
          })}
        </div>
        {question.explanation && (
          <p class="explanation" data-explanation-for={`${id}-q${index + 1}`}>
            <strong>💡 Explanation:</strong> {question.explanation}
          </p>
        )}
      </div>
    ))}
    <button type="submit" class="quiz-submit">Submit Quiz</button>
  </form>
  <div class="quiz-result" id={`result-${id}`}></div>
</div>

<style>
  .quiz-container {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    padding: 30px;
    border-radius: 15px;
    margin: 30px 0;
  }

  .quiz-container h3 {
    color: #667eea;
    margin-bottom: 20px;
    font-size: 1.5em;
  }

  .question {
    margin-bottom: 25px;
    padding-bottom: 20px;
    border-bottom: 1px solid #ddd;
  }

  .question:last-child {
    border-bottom: none;
  }

  .question-text {
    margin-bottom: 15px;
    color: #333;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .option-label {
    display: flex;
    align-items: flex-start;
    padding: 12px 15px;
    background: white;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    border: 2px solid transparent;
  }

  .option-label:hover {
    background: #f0f0f0;
    border-color: #667eea;
  }

  .option-label.selected {
    border-color: #667eea;
    background: #e3f2fd;
  }

  .option-label input[type="radio"] {
    margin-right: 12px;
    margin-top: 3px;
    flex-shrink: 0;
  }

  .option-text {
    flex: 1;
    color: #555;
  }

  .explanation {
    display: none;
    margin-top: 12px;
    padding: 12px;
    background: #e3f2fd;
    border-left: 4px solid #2196f3;
    border-radius: 6px;
    font-size: 0.9em;
  }

  .explanation.show {
    display: block;
  }

  .quiz-submit {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    padding: 15px 40px;
    border-radius: 25px;
    font-size: 1.1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 20px;
  }

  .quiz-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
  }

  .quiz-result {
    margin-top: 20px;
    padding: 20px;
    border-radius: 10px;
    text-align: center;
    font-weight: 600;
    display: none;
  }

  .quiz-result.show {
    display: block;
  }

  .quiz-result.pass {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    color: #155724;
    border: 2px solid #28a745;
  }

  .quiz-result.fail {
    background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
    color: #721c24;
    border: 2px solid #dc3545;
  }

  .quiz-result .score-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin: 0 auto 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2em;
  }

  .quiz-result.pass .score-circle {
    background: white;
    color: #28a745;
  }

  .quiz-result.fail .score-circle {
    background: white;
    color: #dc3545;
  }

  /* Dark mode */
  :global(body.dark-mode) .quiz-container {
    background: linear-gradient(135deg, #2a2a4a 0%, #1a1a2e 100%);
  }

  :global(body.dark-mode) .quiz-container h3 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .question-text {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .option-label {
    background: #252540;
    color: #c0c0c0;
  }

  :global(body.dark-mode) .option-label:hover {
    background: #3a3a5a;
  }

  :global(body.dark-mode) .explanation {
    background: #16213e;
    border-left-color: #a8dadc;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .quiz-container {
      padding: 20px;
    }
  }
</style>

<script>
  // Quiz functionality - scoped to each quiz instance
  document.addEventListener('DOMContentLoaded', () => {
    const quizContainer = document.getElementById(`quiz-${Astro.props.id}`);
    if (!quizContainer) return;

    const form = quizContainer.querySelector('.quiz-form');
    const resultDiv = quizContainer.querySelector('.quiz-result');
    const questions = quizContainer.querySelectorAll('.question');

    if (!form || !resultDiv) return;

    // Track selected options
    form.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target && target.type === 'radio') {
        const label = target.closest('.option-label');
        if (label) {
          label.closest('.options')?.querySelectorAll('.option-label').forEach(l => {
            l.classList.remove('selected');
          });
          label.classList.add('selected');
        }
      }
    });

    // Handle form submission
    form.addEventListener('submit', (e: Event) => {
      e.preventDefault();

      let score = 0;
      let total = questions.length;
      const passingScore = Astro.props.passingScore;
      const quizId = Astro.props.id;

      questions.forEach((question) => {
        const selected = question.querySelector('input[type="radio"]:checked') as HTMLInputElement;
        const correctInput = question.querySelector('input[type="radio"]') as HTMLInputElement;
        const correct = correctInput?.dataset.correct;
        const explanation = question.querySelector('.explanation');

        // Reset classes
        question.querySelectorAll('.option-label').forEach(label => {
          label.classList.remove('correct', 'incorrect');
        });

        if (selected && correct) {
          if (selected.value === correct) {
            score++;
            selected.closest('.option-label')?.classList.add('correct');
          } else {
            selected.closest('.option-label')?.classList.add('incorrect');
            // Highlight correct answer
            question.querySelector(`input[value="${correct}"]`)?.closest('.option-label')?.classList.add('correct');
          }
        }

        // Show explanation
        if (explanation) {
          explanation.classList.add('show');
        }
      });

      const percentage = Math.round((score / total) * 100);
      const passed = percentage >= passingScore;

      resultDiv.innerHTML = `
        <div class="score-circle">${percentage}%</div>
        <p>${passed ? '🎉 Congratulations!' : 'Keep practicing!'}</p>
        <p>You scored ${score} out of ${total} (${percentage}%)</p>
        <p>${passed ? 'You passed this quiz!' : `You need ${passingScore}% to pass. Try again!`}</p>
      `;

      resultDiv.className = `quiz-result show ${passed ? 'pass' : 'fail'}`;

      // Save progress to localStorage
      saveQuizProgress(quizId, percentage, total);

      // Scroll to result
      resultDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });

  // Save quiz progress to localStorage
  function saveQuizProgress(quizId: string, score: number, total: number) {
    const storageKey = 'seoCourseProgress';
    const stored = localStorage.getItem(storageKey);
    const progress = stored ? JSON.parse(stored) : {
      levels: {
        level1: { completed: false, progress: 0 },
        level2: { completed: false, progress: 0 },
        level3: { completed: false, progress: 0 },
        level4: { completed: false, progress: 0 }
      },
      quizzes: {
        quickQuiz: { taken: 0, bestScore: 0 },
        timedChallenge: { taken: 0, bestScore: 0 },
        practiceMode: { taken: 0, bestScore: 0 },
        finalTest: { taken: 0, bestScore: 0 }
      },
      achievements: []
    };

    // Map quiz IDs to progress keys
    const quizKeyMap: Record<string, 'quickQuiz' | 'timedChallenge' | 'practiceMode' | 'finalTest'> = {
      'final-test': 'finalTest',
      'quick-quiz': 'quickQuiz',
      'timed-challenge': 'timedChallenge',
      'practice-mode': 'practiceMode'
    };

    const progressKey = quizKeyMap[quizId];
    if (progressKey && progress.quizzes[progressKey]) {
      progress.quizzes[progressKey].taken++;
      if (score > progress.quizzes[progressKey].bestScore) {
        progress.quizzes[progressKey].bestScore = score;
      }
    }

    localStorage.setItem(storageKey, JSON.stringify(progress));
  }
</script>
