---
/**
 * Sidebar Table of Contents Component
 *
 * Displays a sticky sidebar with navigation links to page sections
 * Includes scroll spy functionality to highlight active section
 *
 * @param sections - Array of section objects with id, title, icon
 * @param title - Sidebar title (default: "Contents")
 */
interface Section {
  id: string;
  title: string;
  icon?: string;
  level?: number;
}

interface Props {
  sections: Section[];
  title?: string;
}

const { sections, title = "📑 Contents" } = Astro.props;
---

<aside class="sidebar-toc" aria-label="Table of contents">
  <div class="sidebar-header">
    <h4>{title}</h4>
    <button class="sidebar-toggle" aria-label="Toggle sidebar" id="sidebarToggle">
      <span class="hamburger">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <nav class="toc-nav" id="tocNav">
    <ul class="toc-list" role="list">
      {sections.map((section) => (
        <li class="toc-item" data-section={section.id}>
          <a
            href={`#${section.id}`}
            class="toc-link"
            data-target={section.id}
            style={section.level ? `--level: ${section.level}` : ''}
          >
            {section.icon && <span class="toc-icon">{section.icon}</span>}
            <span class="toc-text">{section.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar-footer" id="sidebarFooter">
    <button class="back-to-top" id="backToTop" aria-label="Back to top">
      ↑ Top
    </button>
  </div>
</aside>

<div class="backdrop" id="sidebarBackdrop"></div>

<style>
  .sidebar-toc {
    position: fixed;
    top: 0;
    inset-inline-start: 0;
    width: 280px;
    height: 100vh;
    background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
    color: white;
    transform: translateX(-100%);
    transition: transform 0.3s ease-in-out;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .sidebar-toc.open {
    transform: translateX(0);
  }

  /* RTL support */
  [dir="rtl"] .sidebar-toc {
    inset-inline-start: auto;
    inset-inline-end: 0;
  }

  [dir="rtl"] .sidebar-toc {
    transform: translateX(100%);
  }

  [dir="rtl"] .sidebar-toc.open {
    transform: translateX(0);
  }

  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }

  .sidebar-header h4 {
    margin: 0;
    font-size: 1.1em;
    font-weight: 600;
  }

  .sidebar-toggle {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: white;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .sidebar-toggle:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: white;
    border-radius: 2px;
    transition: all 0.3s;
  }

  .toc-nav {
    flex: 1;
    overflow-y: auto;
    padding: 10px 0;
  }

  .toc-nav::-webkit-scrollbar {
    width: 6px;
  }

  .toc-nav::-webkit-scrollbar-track {
    background: transparent;
  }

  .toc-nav::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3);
    border-radius: 3px;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .toc-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: all 0.2s;
    border-inline-start: 3px solid transparent;
  }

  .toc-link:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  .toc-link.active {
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border-inline-start-color: #ffd93d;
    font-weight: 500;
  }

  .toc-icon {
    font-size: 1.1em;
    opacity: 0.9;
  }

  .toc-text {
    flex: 1;
    font-size: 0.9em;
    line-height: 1.4;
  }

  .sidebar-footer {
    padding: 15px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }

  .back-to-top {
    width: 100%;
    padding: 12px;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s;
  }

  .back-to-top:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  /* Backdrop */
  .backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s;
    z-index: 999;
  }

  .backdrop.show {
    opacity: 1;
    visibility: visible;
  }

  /* Desktop: Sidebar visible by default */
  @media (min-width: 1025px) {
    .sidebar-toc {
      transform: translateX(0);
    }

    .sidebar-toggle {
      display: none;
    }
  }

  /* Tablet/Mobile: Sidebar hidden by default */
  @media (max-width: 1024px) {
    .sidebar-toc {
      position: fixed;
      transform: translateX(-100%);
    }

    .sidebar-toc.open {
      transform: translateX(0);
    }
  }

  /* RTL adjustments */
  @media (max-width: 1024px) {
    [dir="rtl"] .sidebar-toc {
      transform: translateX(100%);
    }

    [dir="rtl"] .sidebar-toc.open {
      transform: translateX(0);
    }
  }
</style>

<script>
  const sidebarToc = document.querySelector('.sidebar-toc');
  const sidebarToggle = document.getElementById('sidebarToggle');
  const sidebarBackdrop = document.getElementById('sidebarBackdrop');
  const backToTopBtn = document.getElementById('backToTop');
  const tocLinks = document.querySelectorAll('.toc-link');

  // Toggle sidebar
  sidebarToggle?.addEventListener('click', () => {
    sidebarToc?.classList.toggle('open');
    sidebarBackdrop?.classList.toggle('show');
  });

  // Close sidebar when clicking backdrop
  sidebarBackdrop?.addEventListener('click', () => {
    sidebarToc?.classList.remove('open');
    sidebarBackdrop?.classList.remove('show');
  });

  // Close sidebar when clicking a link (mobile)
  tocLinks.forEach(link => {
    link.addEventListener('click', (e: Event) => {
      e.preventDefault();
      const href = link.getAttribute('href');
      if (href && href.startsWith('#')) {
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });

          // Close sidebar on mobile
          if (window.innerWidth <= 1024) {
            sidebarToc?.classList.remove('open');
            sidebarBackdrop?.classList.remove('show');
          }
        }
      }
    });
  });

  // Back to top
  backToTopBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Scroll spy - highlight active section
  // Query sections from DOM using data-section attributes
  const tocItems = document.querySelectorAll('.toc-item');
  const sections = Array.from(tocItems)
    .map(item => {
      const sectionId = item.getAttribute('data-section');
      return sectionId ? document.getElementById(sectionId) : null;
    })
    .filter((el): el is HTMLElement => el !== null);

  function updateActiveLink() {
    const scrollPosition = window.pageYOffset + 150;

    let activeId = '';
    for (const section of sections) {
      if (!section) continue;
      const sectionTop = section.offsetTop;
      if (scrollPosition >= sectionTop) {
        activeId = section.id;
      }
    }

    tocLinks.forEach(link => {
      link.classList.remove('active');
      const target = link as HTMLElement;
      if (target.dataset.target === activeId) {
        link.classList.add('active');
      }
    });
  }

  let ticking = false;
  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        updateActiveLink();
        ticking = false;
      });
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });

  // Initial call
  setTimeout(updateActiveLink, 100);
</script>
