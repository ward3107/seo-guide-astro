---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Timed Challenge | Waseem's SEO Guide">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={`${base}/`}>Home</a></li>
      <li><a href={`${base}/quick-quiz`}>Quick Quiz</a></li>
      <li aria-current="page">Timed Challenge</li>
    </ol>
  </nav>

  <header>
    <span class="badge">⏱️ TIMED CHALLENGE</span>
    <h1>Beat the Clock!</h1>
    <p class="subtitle">Answer as many questions as you can in 2 minutes • Test your SEO knowledge under pressure</p>
  </header>

  <!-- Start Screen -->
  <section class="start-screen" id="startScreen">
    <div class="start-content">
      <h2>🎯 Ready to Race Against Time?</h2>
      <div class="rules">
        <h3>Rules:</h3>
        <ul>
          <li>⏱️ You have <strong>2 minutes</strong> (120 seconds)</li>
          <li>❓ Answer as many questions as you can</li>
          <li>✅ Correct answers: +1 point</li>
          <li>❌ Wrong answers: 0 points (no penalty)</li>
          <li>🚫 No skipping - you must answer each question</li>
        </ul>
      </div>
      <div class="time-options">
        <h3>Choose Difficulty:</h3>
        <div class="time-buttons">
          <button class="time-btn easy" data-time="180">
            <span class="time-label">Easy Mode</span>
            <span class="time-value">3 minutes</span>
          </button>
          <button class="time-btn normal" data-time="120">
            <span class="time-label">Normal Mode</span>
            <span class="time-value">2 minutes</span>
          </button>
          <button class="time-btn hard" data-time="60">
            <span class="time-label">Hard Mode</span>
            <span class="time-value">1 minute</span>
          </button>
        </div>
      </div>
      <button class="start-btn" id="startBtn">Start Challenge →</button>
    </div>
  </section>

  <!-- Quiz Screen (hidden initially) -->
  <section class="quiz-screen" id="quizScreen" style="display: none;">
    <div class="quiz-header">
      <div class="timer-display">
        <span class="timer-icon">⏱️</span>
        <span class="timer-value" id="timerValue">02:00</span>
      </div>
      <div class="score-display">
        <span class="score-icon">🏆</span>
        <span class="score-value">Score: <span id="currentScore">0</span></span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill"></div>
      </div>
    </div>

    <div class="question-container" id="questionContainer">
      <!-- Questions will be injected here -->
    </div>
  </section>

  <!-- Results Screen (hidden initially) -->
  <section class="results-screen" id="resultsScreen" style="display: none;">
    <div class="results-content">
      <div class="final-score"></div>
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-value" id="statCorrect">0</span>
          <span class="stat-label">Correct</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="statWrong">0</span>
          <span class="stat-label">Wrong</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="statTotal">0</span>
          <span class="stat-label">Answered</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="statAccuracy">0%</span>
          <span class="stat-label">Accuracy</span>
        </div>
      </div>
      <div class="result-message" id="resultMessage"></div>
      <div class="action-buttons">
        <button class="retry-btn" id="retryBtn">Try Again</button>
        <a href={`${base}/quick-quiz`} class="other-quiz-btn">Quick Quiz</a>
        <a href={`${base}/final-test`} class="other-quiz-btn">Full Test</a>
      </div>
    </div>
  </section>

  <div class="back-home">
    <a href={`${base}/`}>← Back to Home</a>
  </div>
</Layout>

<style>
  .start-screen {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 20px;
    padding: 50px 40px;
    text-align: center;
    max-width: 800px;
    margin: 0 auto 40px;
  }

  .start-content h2 {
    color: #667eea;
    font-size: 2em;
    margin-bottom: 30px;
  }

  .rules {
    background: white;
    border-radius: 15px;
    padding: 25px;
    margin-bottom: 30px;
    text-align: left;
  }

  .rules h3 {
    color: #333;
    margin-bottom: 15px;
    font-size: 1.1em;
  }

  .rules ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .rules li {
    padding: 10px 0;
    color: #555;
    font-size: 1.05em;
    border-bottom: 1px dashed #ddd;
  }

  .rules li:last-child {
    border-bottom: none;
  }

  .time-options {
    background: white;
    border-radius: 15px;
    padding: 25px;
    margin-bottom: 30px;
  }

  .time-options h3 {
    color: #333;
    margin-bottom: 20px;
    text-align: center;
    font-size: 1.1em;
  }

  .time-buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }

  .time-btn {
    padding: 20px 30px;
    border: 3px solid;
    border-radius: 15px;
    cursor: pointer;
    transition: all 0.3s ease;
    flex: 1;
    min-width: 150px;
  }

  .time-btn .time-label {
    display: block;
    font-weight: 600;
    margin-bottom: 5px;
  }

  .time-btn .time-value {
    display: block;
    font-size: 0.9em;
    opacity: 0.8;
  }

  .time-btn.easy {
    border-color: #11998e;
    background: #e8f8f5;
    color: #11998e;
  }

  .time-btn.easy:hover {
    background: #11998e;
    color: white;
  }

  .time-btn.normal {
    border-color: #667eea;
    background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
    color: #667eea;
  }

  .time-btn.normal:hover {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .time-btn.hard {
    border-color: #f5576c;
    background: #fff0f3;
    color: #f5576c;
  }

  .time-btn.hard:hover {
    background: #f5576c;
    color: white;
  }

  .start-btn {
    padding: 20px 60px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 50px;
    font-size: 1.2em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
  }

  .start-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
  }

  /* Quiz Screen */
  .quiz-header {
    position: sticky;
    top: 0;
    background: white;
    padding: 20px;
    border-radius: 15px;
    margin-bottom: 20px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .timer-display, .score-display {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.2em;
    font-weight: 600;
  }

  .timer-display {
    color: #f5576c;
  }

  .score-display {
    color: #667eea;
  }

  .progress-bar {
    flex: 1;
    min-width: 200px;
    height: 8px;
    background: #e9ecef;
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
    width: 0%;
    transition: width 0.3s ease;
  }

  .progress-fill.warning {
    background: #ffc107;
  }

  .progress-fill.danger {
    background: #f5576c;
  }

  .question-container {
    max-width: 700px;
    margin: 0 auto;
  }

  .question-card {
    background: white;
    border-radius: 16px;
    padding: 30px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    border-left: 5px solid #667eea;
  }

  .question-text {
    font-size: 1.3em;
    color: #333;
    margin: 0 0 25px 0;
    line-height: 1.5;
  }

  .options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }

  .option-btn {
    padding: 20px;
    border: 2px solid #e0e0e0;
    border-radius: 12px;
    background: white;
    cursor: pointer;
    font-size: 1em;
    color: #555;
    transition: all 0.2s ease;
    text-align: left;
  }

  .option-btn:hover {
    border-color: #667eea;
    background: #f8f9ff;
  }

  .option-btn.correct {
    border-color: #28a745;
    background: #d4edda;
    color: #155724;
  }

  .option-btn.incorrect {
    border-color: #dc3545;
    background: #f8d7da;
    color: #721c24;
  }

  /* Results Screen */
  .results-screen {
    background: white;
    border-radius: 20px;
    padding: 50px 40px;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .final-score {
    font-size: 4em;
    font-weight: bold;
    margin-bottom: 10px;
  }

  .final-score.excellent {
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .final-score.good {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .final-score.needs-work {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 30px;
  }

  .stat-item {
    padding: 20px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 12px;
  }

  .stat-value {
    display: block;
    font-size: 2em;
    font-weight: bold;
    color: #333;
  }

  .stat-label {
    font-size: 0.9em;
    color: #666;
  }

  .result-message {
    font-size: 1.3em;
    color: #333;
    margin-bottom: 30px;
    line-height: 1.5;
  }

  .action-buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }

  .retry-btn, .other-quiz-btn {
    padding: 15px 30px;
    border-radius: 50px;
    font-size: 1em;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .retry-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
  }

  .other-quiz-btn {
    background: #f8f9fa;
    color: #667eea;
    border: 2px solid #667eea;
  }

  .retry-btn:hover, .other-quiz-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
  }

  .back-home {
    text-align: center;
    margin: 40px 0;
  }

  .back-home a {
    display: inline-block;
    padding: 15px 30px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
  }

  .back-home a:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
  }

  /* Timer warning colors */
  .timer-value.warning {
    color: #ffc107;
  }

  .timer-value.danger {
    color: #f5576c;
    animation: pulse 0.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Dark mode */
  :global(body.dark-mode) .start-screen {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }

  :global(body.dark-mode) .rules, :global(body.dark-mode) .time-options {
    background: #252540;
  }

  :global(body.dark-mode) .rules h3, :global(body.dark-mode) .time-options h3 {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .rules li {
    color: #b0b0b0;
    border-bottom-color: #3a3a5a;
  }

  :global(body.dark-mode) .quiz-header {
    background: #252540;
  }

  :global(body-dark-mode) .question-card {
    background: #252540;
  }

  :global(body.dark-mode) .question-text {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .option-btn {
    background: #2a2a4a;
    border-color: #3a3a5a;
    color: #b0b0b0;
  }

  :global(body.dark-mode) .option-btn:hover {
    border-color: #667eea;
    background: #3a3a5a;
  }

  :global(body.dark-mode) .results-screen {
    background: #252540;
  }

  :global(body.dark-mode) .final-score.needs-work {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .stat-item {
    background: #2a2a4a;
  }

  :global(body.dark-mode) .stat-value {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .stat-label {
    color: #b0b0b0;
  }

  :global(body.dark-mode) .result-message {
    color: #e0e0e0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .time-buttons {
      flex-direction: column;
    }

    .time-btn {
      min-width: 100%;
    }

    .quiz-header {
      flex-direction: column;
      gap: 15px;
    }

    .options {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .action-buttons {
      flex-direction: column;
    }

    .retry-btn, .other-quiz-btn {
      width: 100%;
    }
  }
</style>

