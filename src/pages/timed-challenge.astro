  const retryBtn = document.getElementById('retryBtn');
  const timerValue = document.getElementById('timerValue');
  const currentScore = document.getElementById('currentScore');
  const progressFill = document.getElementById('progressFill');
  const questionContainer = document.getElementById('questionContainer');

  // Shuffle function
  function shuffleArray<T>(array: T[]): T[] {
    const shuffled = [...array];
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
  }

  // Format time display
  function formatTime(seconds: number): string {
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
  }

  // Update timer display
  function updateTimerDisplay() {
    if (!timerValue || !progressFill) return;
    timerValue.textContent = formatTime(gameState.timeLeft);

    // Warning at 30 seconds
    if (gameState.timeLeft <= 30 && gameState.timeLeft > 10) {
      timerValue.classList.add('warning');
      progressFill.classList.add('warning');
    }
    // Danger at 10 seconds
    else if (gameState.timeLeft <= 10) {
      timerValue.classList.remove('warning');
      timerValue.classList.add('danger');
      progressFill.classList.remove('warning');
      progressFill.classList.add('danger');
    }
    else {
      timerValue.classList.remove('warning', 'danger');
      progressFill.classList.remove('warning', 'danger');
    }
  }

  // Update progress bar
  function updateProgress() {
    if (!progressFill || gameState.questions.length === 0) return;
    const progress = ((gameState.currentQuestion + 1) / gameState.questions.length) * 100;
    progressFill.style.width = `${progress}%`;
  }

  // Start game
  function startGame(timeLimit: number) {
    gameState = {
      timeLeft: timeLimit,
      totalTime: timeLimit,
      score: 0,
      correct: 0,
      wrong: 0,
      currentQuestion: 0,
      questions: shuffleArray(allQuestions),
      timerInterval: null,
      isActive: true
    };

    // Show quiz screen
    if (startScreen) startScreen.style.display = 'none';
    if (quizScreen) quizScreen.style.display = 'block';
    if (resultsScreen) resultsScreen.style.display = 'none';

    // Reset displays
    if (currentScore) currentScore.textContent = '0';
    if (timerValue) timerValue.classList.remove('warning', 'danger');
    if (progressFill) progressFill.classList.remove('warning', 'danger');

    // Show first question
    showQuestion();
    updateProgress();

    // Start timer
    updateTimerDisplay();
    gameState.timerInterval = window.setInterval(() => {
      gameState.timeLeft--;
      updateTimerDisplay();

      if (gameState.timeLeft <= 0) {
        endGame();
      }
    }, 1000);
  }

  // Show question
  function showQuestion() {
    if (!questionContainer) return;
    const q = gameState.questions[gameState.currentQuestion];

    questionContainer.innerHTML = `
      <div class="question-card">
        <p class="question-text">${q.q}</p>
        <div class="options">
          ${q.options.map((opt: string, index: number) => {
            const letter = String.fromCharCode(97 + index);
            return `
              <button class="option-btn" data-answer="${letter}">
                ${letter.toUpperCase()}) ${opt}
              </button>
            `;
          }).join('')}
        </div>
      </div>
    `;

    // Add click handlers
    const buttons = questionContainer.querySelectorAll('.option-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => handleAnswer((btn as HTMLElement).dataset.answer || ''));
    });
  }

  // Handle answer
  function handleAnswer(answer: string) {
    if (!gameState.isActive || !questionContainer) return;

    const q = gameState.questions[gameState.currentQuestion];
    const isCorrect = answer === q.correct;

    if (isCorrect) {
      gameState.score++;
      gameState.correct++;
    } else {
      gameState.wrong++;
    }

    if (currentScore) currentScore.textContent = gameState.score.toString();

    // Show feedback briefly
    const buttons = questionContainer.querySelectorAll('.option-btn');
    buttons.forEach(btn => {
      const btnEl = btn as HTMLButtonElement;
      const btnAnswer = btnEl.dataset.answer || '';
      if (btnAnswer === q.correct) {
        btnEl.classList.add('correct');
      } else if (btnAnswer === answer) {
        btnEl.classList.add('incorrect');
      }
      btnEl.disabled = true;
    });

    // Move to next question or end
    setTimeout(() => {
      gameState.currentQuestion++;

      if (gameState.currentQuestion >= gameState.questions.length) {
        endGame();
      } else {
        showQuestion();
        updateProgress();
      }
    }, 500);
  }

  // End game
  function endGame() {
    gameState.isActive = false;
    if (gameState.timerInterval !== null) {
      clearInterval(gameState.timerInterval);
    }

    // Show results
    if (quizScreen) quizScreen.style.display = 'none';
    if (resultsScreen) resultsScreen.style.display = 'block';

    // Update stats
    const statCorrect = document.getElementById('statCorrect') as HTMLElement;
    const statWrong = document.getElementById('statWrong') as HTMLElement;
    const statTotal = document.getElementById('statTotal') as HTMLElement;
    const statAccuracy = document.getElementById('statAccuracy') as HTMLElement;
    const finalScore = document.querySelector('.final-score') as HTMLElement;
    const messageDiv = document.getElementById('resultMessage') as HTMLElement;

    if (statCorrect) statCorrect.textContent = gameState.correct.toString();
    if (statWrong) statWrong.textContent = gameState.wrong.toString();
    if (statTotal) statTotal.textContent = (gameState.correct + gameState.wrong).toString();

    const accuracy = gameState.correct + gameState.wrong > 0
      ? Math.round((gameState.correct / (gameState.correct + gameState.wrong)) * 100)
      : 0;
    if (statAccuracy) statAccuracy.textContent = `${accuracy}%`;

    // Show final score
    let scoreClass = 'needs-work';
    let message = '';

    if (accuracy >= 90) {
      scoreClass = 'excellent';
      message = '🏆 Outstanding! You\'re an SEO speed demon!';
    } else if (accuracy >= 75) {
      scoreClass = 'good';
      message = `👏 Great job! You got ${gameState.correct} out of ${gameState.correct + gameState.wrong} correct!`;
    } else if (accuracy >= 60) {
      scoreClass = 'good';
      message = `👍 Good effort! You got ${gameState.correct} correct answers.`;
    } else {
      message = `📚 Keep practicing! You got ${gameState.correct} correct answers.`;
    }

    if (finalScore) {
      finalScore.textContent = `${accuracy}%`;
      finalScore.className = `final-score ${scoreClass}`;
    }
    if (messageDiv) messageDiv.textContent = message;
  }

  // Event listeners
  document.querySelectorAll('.time-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const time = parseInt((btn as HTMLElement).dataset.time || '120');
      startGame(time);
    });
  });

  startBtn?.addEventListener('click', () => {
    startGame(120); // Default to 2 minutes
  });

  retryBtn?.addEventListener('click', () => {
    location.reload();
  });
</script>
