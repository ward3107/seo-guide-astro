<script>
  // Fisher-Yates shuffle algorithm
  function shuffleArray<T>(array: T[]): T[] {
    const shuffled = [...array];
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
  }

  // Shuffle quiz options on page load
  function shuffleQuizOptions() {
    const questions = document.querySelectorAll('.question');

    questions.forEach((questionEl, questionIndex) => {
      const options = questionEl.querySelectorAll('.question label');
      const optionData: Array<{ element: HTMLElement; text: string; value: string }> = [];

      // Collect option data
      options.forEach((opt, idx) => {
        const input = opt.querySelector('input') as HTMLInputElement;
        optionData.push({
          element: opt as HTMLElement,
          text: opt.textContent?.trim() || '',
          value: input?.value || String.fromCharCode(97 + idx)
        });
      });

      // Shuffle options
      const shuffled = shuffleArray(optionData);

      // Reorder options and update values
      const optionsContainer = questionEl.querySelector(':scope > .question-text')?.nextElementSibling;
      if (optionsContainer) {
        shuffled.forEach((opt, idx) => {
          const newValue = String.fromCharCode(97 + idx); // a, b, c, d...
          const input = opt.element.querySelector('input') as HTMLInputElement;
          if (input) {
            input.name = `q${questionIndex + 1}`;
            input.value = newValue;
          }
          // Update data-letter attribute
          opt.element.setAttribute('data-letter', String.fromCharCode(65 + idx)); // A, B, C, D...
          optionsContainer.appendChild(opt.element);
        });
      }
    });
  }

  // Store original correct answers before shuffling
  const originalAnswers = {
    q1: 'b',
    q2: 'b',
    q3: 'b',
    q4: 'b',
    q5: 'b',
    q6: 'b',
    q7: 'b',
    q8: 'b',
    q9: 'b',
    q10: 'c'
  };

  // After shuffling, we need to track where correct answers ended up
  // For simplicity in level quizzes, we'll mark correct answers with a data attribute
  function markCorrectAnswers() {
    const correctMap: Record<string, string> = originalAnswers;

    document.querySelectorAll('.question').forEach((questionEl, questionIndex) => {
      const questionNum = questionIndex + 1;
      const correctLetter = correctMap[`q${questionNum}`];

      // Find the label with the correct text content and mark it
      const labels = questionEl.querySelectorAll('.question label');
      labels.forEach(label => {
        const input = label.querySelector('input') as HTMLInputElement;
        if (input && input.value === correctLetter) {
          input.dataset.correct = correctLetter;
        }
      });
    });
  }

  // Run shuffle on page load
  shuffleQuizOptions();
  markCorrectAnswers();

  // Quiz functionality
  const quizForm = document.getElementById('quiz');
  const quizResult = document.getElementById('quizResult');

  const answers = {
    q1: 'b',
    q2: 'b',
    q3: 'b',
    q4: 'b',
    q5: 'b',
    q6: 'b',
    q7: 'b',
    q8: 'b',
    q9: 'b',
    q10: 'c'
  };

  if (quizForm && quizResult) {
    quizForm.addEventListener('submit', (e: Event) => {
      e.preventDefault();

      let score = 0;
      const questionCards = quizForm.querySelectorAll('.question');

      questionCards.forEach((card) => {
        const selected = card.querySelector('input[type="radio"]:checked') as HTMLInputElement;
        const correctInput = card.querySelector('input[data-correct]') as HTMLInputElement;

        if (selected && correctInput && selected.value === correctInput.dataset.correct) {
          score++;
        }
      });

      const total = questionCards.length;

      const percentage = (score / total) * 100;

      quizResult.className = 'quiz-result';
      if (percentage >= 75) {
        quizResult.classList.add('pass');
        quizResult.textContent = `🎉 Great job! You scored ${score}/${total} (${percentage}%)`;
      } else {
        quizResult.classList.add('fail');
        quizResult.textContent = `Keep practicing! You scored ${score}/${total} (${percentage}%). Try again!`;
      }
    });
  }
</script>
