---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const levelNumber = 1;
const levelTitle = 'SEO & GEO Basics';
const levelSubtitle = 'The 5 Essential HTML Tools for Making Websites Search-Friendly';
---

<Layout title={`Level ${levelNumber}: ${levelTitle} | Waseem's SEO Guide`}>
  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li aria-current="page">Level {levelNumber}: {levelTitle}</li>
    </ol>
  </nav>

  <header>
    <span class="badge">LEVEL {levelNumber}</span>
    <h1>📘 {levelTitle}</h1>
    <p class="subtitle">{levelSubtitle}</p>
    <div class="reading-time-badge">⏱️ ~30 min read</div>
    <div class="meta">
      <strong>Created for:</strong> Waseem (English Teacher & Coder)<br />
      <strong>Level:</strong> Beginner - No prior SEO knowledge needed<br />
      <strong>Date:</strong> February 2026<br />
      <strong>Format:</strong> Learn → Practice → Quiz
    </div>
  </header>

  <!-- Table of Contents -->
  <section class="toc-section">
    <h3>📑 Table of Contents</h3>
    <ul class="toc-list">
      <li><a href="#intro">🧠 Introduction: What is SEO & GEO?</a></li>
      <li><a href="#library">📚 The Library Analogy</a></li>
      <li><a href="#tools">🛠️ The 5 Essential HTML Tools</a></li>
      <li><a href="#title">Tool #1: The Title Tag</a></li>
      <li><a href="#h1">Tool #2: The H1 Heading</a></li>
      <li><a href="#links">Tool #3: Links (Anchor Tags)</a></li>
      <li><a href="#alt">Tool #4: Alt Attributes</a></li>
      <li><a href="#schema">Tool #5: Schema Markup</a></li>
      <li><a href="#intent">Search Intent: The "Why"</a></li>
      <li><a href="#practice">✅ Practice Checklist</a></li>
      <li><a href="#quiz">📝 Quiz</a></li>
    </ul>
  </section>

  <!-- Introduction -->
  <section id="intro">
    <h2>🧠 What is SEO & GEO?</h2>

    <div class="learn-box">
      <h4>🎓 Learn</h4>
      <p><strong>SEO</strong> = Search Engine Optimization - making your website appear in Google, Bing, etc.</p>
      <p><strong>GEO</strong> = Generative Engine Optimization - making your content useful for AI like ChatGPT.</p>
    </div>

    <div class="reflect-box">
      <h4>🤔 Reflect</h4>
      <p>When you search for something, where do you click first? The top 3 results? That's SEO at work.</p>
      <p>When you ask ChatGPT a question, how does it know what to say? That's GEO.</p>
    </div>

    <div class="tip-box">
      <h4>💡 Key Insight</h4>
      <p>SEO and GEO are cousins. They both want <strong>clear, accurate, helpful information</strong>.</p>
    </div>
  </section>

  <!-- The Library Analogy -->
  <section id="library">
    <h2>📚 The Library Analogy</h2>

    <div class="learn-box">
      <h4>🎓 Learn</h4>
      <p>Think of Google as a giant library. Your website is a book in that library.</p>

      <ul>
        <li><strong>The Title Tag</strong> = The book's title on the spine</li>
        <li><strong>The H1 Heading</strong> = The chapter title on the first page</li>
        <li><strong>Links</strong> = References to other books</li>
        <li><strong>Alt Text</strong> = Descriptions of pictures for blind readers</li>
        <li><strong>Schema</strong> = The catalog card with book details</li>
      </ul>
    </div>

    <div class="reflect-box">
      <h4>🤔 Reflect</h4>
      <p>Would you find a book with no title? No author? No description? That's what a website without SEO looks like to Google.</p>
    </div>
  </section>

  <!-- The 5 Essential Tools -->
  <section id="tools">
    <h2>🛠️ The 5 Essential HTML Tools</h2>

    <p>These 5 HTML elements are the foundation of SEO. Master these, and you're ahead of 90% of websites.</p>

    <div class="tools-grid">
      <div class="tool-card">
        <span class="tool-number">1</span>
        <h3>Title Tag</h3>
        <p>The most important SEO element</p>
      </div>
      <div class="tool-card">
        <span class="tool-number">2</span>
        <h3>H1 Heading</h3>
        <p>Your main page headline</p>
      </div>
      <div class="tool-card">
        <span class="tool-number">3</span>
        <h3>Links</h3>
        <p>Connect your content</p>
      </div>
      <div class="tool-card">
        <span class="tool-number">4</span>
        <h3>Alt Attributes</h3>
        <p>Describe your images</p>
      </div>
      <div class="tool-card">
        <span class="tool-number">5</span>
        <h3>Schema Markup</h3>
        <p>Help search engines understand</p>
      </div>
    </div>
  </section>

  <!-- Tool #1: Title Tag -->
  <section id="title">
    <h2>🏷️ Tool #1: The Title Tag</h2>

    <div class="learn-box">
      <h4>🎓 Learn</h4>
      <p>The <code>&lt;title&gt;</code> tag appears in the browser tab and is the main blue link in search results.</p>

      <pre><code>&lt;title&gt;Waseem | English Teacher & SEO Coder&lt;/title&gt;</code></pre>

      <p><strong>Best Practices:</strong></p>
      <ul>
        <li>Keep it under 60 characters</li>
        <li>Put important keywords first</li>
        <li>Make it readable for humans</li>
        <li>Include your brand name at the end</li>
      </ul>
    </div>

    <div class="practice-box">
      <h4>✍️ Practice</h4>
      <p>Write a title tag for:</p>
      <ol>
        <li>A coffee shop in Haifa</li>
        <li>A JavaScript tutorial for beginners</li>
        <li>A recipe for chocolate chip cookies</li>
      </ol>
    </div>

    <div class="verify-box">
      <h4>✅ Verify</h4>
      <ul>
        <li>Is each under 60 characters?</li>
        <li>Does it include the main keyword?</li>
        <li>Would a human want to click it?</li>
      </ul>
    </div>
  </section>

  <!-- Tool #2: H1 Heading -->
  <section id="h1">
    <h2>📌 Tool #2: The H1 Heading</h2>

    <div class="learn-box">
      <h4>🎓 Learn</h4>
      <p>The <code>&lt;h1&gt;</code> is your main page heading. Think of it as the chapter title of your page.</p>

      <pre><code>&lt;h1&gt;SEO Basics: The Complete Guide&lt;/h1&gt;</code></pre>

      <p><strong>Rules:</strong></p>
      <ul>
        <li>Use only ONE H1 per page</li>
        <li>Make it descriptive and compelling</li>
        <li>Include your main keyword naturally</li>
        <li>Match what the page is actually about</li>
      </ul>
    </div>

    <div class="reflect-box">
      <h4>🤔 Reflect</h4>
      <p>What's the difference between a Title Tag and an H1?</p>
      <p><em>Answer: Title is for search results (external), H1 is for page visitors (internal).</em></p>
    </div>
  </section>

  <!-- Tool #3: Links -->
  <section id="links">
    <h2>🔗 Tool #3: Links (Anchor Tags)</h2>

    <div class="learn-box">
      <h4>🎓 Learn</h4>
      <p>Links help search engines discover pages and understand what's important.</p>

      <pre><code>&lt;a href="about.html"&gt;About Me&lt;/a&gt;</code></pre>

      <p><strong>Types of Links:</strong></p>
      <ul>
        <li><strong>Internal links:</strong> Connect your pages together</li>
        <li><strong>External links:</strong> Link to other trusted sites</li>
        <li><strong>Anchor text:</strong> The clickable words (make them descriptive!)</li>
      </ul>
    </div>

    <div class="tip-box">
      <h4>💡 Pro Tip</h4>
      <p>Good anchor: <a href="#">"Learn SEO basics"</a></p>
      <p>Bad anchor: <a href="#">"Click here"</a></p>
    </div>
  </section>

  <!-- Tool #4: Alt Attributes -->
  <section id="alt">
    <h2>🖼️ Tool #4: Alt Attributes</h2>

    <div class="learn-box">
      <h4>🎓 Learn</h4>
      <p>The <code>alt</code> attribute describes images for search engines and accessibility.</p>

      <pre><code>&lt;img src="waseem.jpg" alt="Waseem teaching English in a Haifa classroom"&gt;</code></pre>

      <p><strong>Why it matters:</strong></p>
      <ul>
        <li>Helps blind users (screen readers read it aloud)</li>
        <li>Tells Google what the image shows</li>
        <li>Helps rank in Google Images</li>
      </ul>
    </div>

    <div class="practice-box">
      <h4>✍️ Practice</h4>
      <p>Write alt text for:</p>
      <ol>
        <li>A logo for "Waseem's English School"</li>
        <li>A photo of you teaching a class</li>
        <li>A screenshot of code</li>
      </ol>
    </div>
  </section>

  <!-- Tool #5: Schema Markup -->
  <section id="schema">
    <h2>📊 Tool #5: Schema Markup</h2>

    <div class="learn-box">
      <h4>🎓 Learn</h4>
      <p>Schema is code that tells search engines exactly what your content means.</p>

      <pre><code>&lt;script type="application/ld+json"&gt;
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Waseem",
  "jobTitle": "English Teacher"
}
&lt;/script&gt;</code></pre>

      <p><strong>Why it's powerful:</strong></p>
      <ul>
        <li>Creates rich snippets (star ratings, prices, etc.)</li>
        <li>Helps AI understand your content</li>
        <li>Stands out in search results</li>
      </ul>
    </div>

    <div class="reflect-box">
      <h4>🤔 Reflect</h4>
      <p>Schema is like giving Google a cheat sheet about your content. The more they understand, the better they can rank you.</p>
    </div>
  </section>

  <!-- Search Intent -->
  <section id="intent">
    <h2>🎯 Search Intent: The "Why"</h2>

    <div class="learn-box">
      <h4>🎓 Learn</h4>
      <p>Search intent is WHY someone searches. Match their intent, rank higher.</p>

      <p><strong>The 4 Types:</strong></p>
      <ul>
        <li><strong>Informational:</strong> "How to bake bread"</li>
        <li><strong>Navigational:</strong> "Facebook login"</li>
        <li><strong>Transactional:</strong> "Buy iPhone 15"</li>
        <li><strong>Commercial:</strong> "Best laptop 2024"</li>
      </ul>
    </div>

    <div class="practice-box">
      <h4>✍️ Practice</h4>
      <p>What's the search intent for:</p>
      <ol>
        <li>"SEO basics"</li>
        <li>"order pizza online"</li>
        <li>"Waseem English teacher"</li>
      </ol>
    </div>
  </section>

  <!-- Practice Checklist -->
  <section id="practice">
    <h2>✅ Practice Checklist</h2>

    <div class="checklist">
      <label><input type="checkbox" /> Title tag under 60 characters</label>
      <label><input type="checkbox" /> One H1 heading per page</label>
      <label><input type="checkbox" /> All images have alt text</label>
      <label><input type="checkbox" /> Internal links between pages</label>
      <label><input type="checkbox" /> Schema markup added</label>
      <label><input type="checkbox" /> Content matches search intent</label>
    </div>
  </section>

  <!-- Why Companies Hire Coders -->
  <section>
    <h2>💼 Why Companies Hire Coders for SEO</h2>

    <p>Many people think SEO = "writing blog posts." That's only 20% of the story.</p>

    <p><strong>The other 80% requires coding:</strong></p>
    <ul>
      <li>Fixing technical issues (broken links, slow pages)</li>
      <li>Implementing schema markup</li>
      <li>Optimizing site structure</li>
      <li>Monitoring analytics and fixing problems</li>
      <li>Keeping up with algorithm updates</li>
    </ul>

    <div class="tip-box">
      <h4>💡 Your Advantage</h4>
      <p>As someone who can CODE and understands SEO, you're in the top 5% of job candidates.</p>
    </div>
  </section>

  <!-- Quiz Section -->
  <section id="quiz" class="quiz-section">
    <h2>📝 Level 1 Quiz: SEO Basics</h2>

    <form id="quiz" class="quiz-form">
      <div class="question" data-question="1">
        <p><strong>1. What is the primary purpose of the title tag?</strong></p>
        <label><input type="radio" name="q1" value="a"> a) Describe images</label>
        <label><input type="radio" name="q1" value="b"> b) Display in browser tab and search results</label>
        <label><input type="radio" name="q1" value="c"> c) Create links</label>
        <label><input type="radio" name="q1" value="d"> d) Style the page</label>
      </div>

      <div class="question" data-question="2">
        <p><strong>2. How many H1 headings should a page have?</strong></p>
        <label><input type="radio" name="q2" value="a"> a) Zero</label>
        <label><input type="radio" name="q2" value="b"> b) One</label>
        <label><input type="radio" name="q2" value="c"> c) Multiple</label>
        <label><input type="radio" name="q2" value="d"> d) As many as you want</label>
      </div>

      <div class="question" data-question="3">
        <p><strong>3. What does the alt attribute do?</strong></p>
        <label><input type="radio" name="q3" value="a"> a) Makes images load faster</label>
        <label><input type="radio" name="q3" value="b"> b) Describes images for accessibility and SEO</label>
        <label><input type="radio" name="q3" value="c"> c) Creates image captions</label>
        <label><input type="radio" name="q3" value="d"> d) Nothing important</label>
      </div>

      <div class="question" data-question="4">
        <p><strong>4. What is schema markup?</strong></p>
        <label><input type="radio" name="q4" value="a"> a) A styling framework</label>
        <label><input type="radio" name="q4" value="b"> b) Structured data that helps search engines understand content</label>
        <label><input type="radio" name="q4" value="c"> c) A database system</label>
        <label><input type="radio" name="q4" value="d"> d) A type of link</label>
      </div>

      <button type="submit" class="quiz-submit">Submit Quiz</button>
      <div id="quizResult" class="quiz-result"></div>
    </form>
  </section>

  <!-- Navigation Footer -->
  <nav class="level-nav">
    <a href="/" class="nav-btn">← Back to Home</a>
    <a href="/level2" class="nav-btn">Level 2: Technical SEO →</a>
  </nav>
</Layout>

<style>
  /* Breadcrumbs */
  .breadcrumbs {
    margin-bottom: 30px;
  }

  .breadcrumbs ol {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 8px;
    flex-wrap: wrap;
  }

  .breadcrumbs li {
    color: #666;
  }

  .breadcrumbs li:not(:last-child)::after {
    content: '→';
    margin-left: 8px;
    color: #999;
  }

  .breadcrumbs a {
    color: #667eea;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  /* Header */
  header {
    text-align: center;
    margin-bottom: 40px;
  }

  .badge {
    display: inline-block;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 8px 20px;
    border-radius: 25px;
    font-weight: 600;
    margin-bottom: 20px;
  }

  header h1 {
    font-size: 2.5em;
    margin-bottom: 10px;
    color: #333;
  }

  .subtitle {
    font-size: 1.3em;
    color: #667eea;
    margin-bottom: 20px;
  }

  .reading-time-badge {
    display: inline-block;
    background: #f0f0f0;
    padding: 6px 16px;
    border-radius: 15px;
    font-size: 0.9em;
    color: #666;
  }

  .meta {
    margin-top: 20px;
    color: #666;
    line-height: 1.8;
  }

  /* Table of Contents */
  .toc-section {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    padding: 25px;
    border-radius: 15px;
    margin-bottom: 40px;
  }

  .toc-section h3 {
    margin-bottom: 15px;
    color: #667eea;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-list li {
    margin-bottom: 8px;
  }

  .toc-list a {
    color: #555;
    text-decoration: none;
    display: block;
    padding: 8px 12px;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .toc-list a:hover {
    background: rgba(102, 126, 234, 0.1);
    color: #667eea;
  }

  /* Content Boxes */
  .learn-box,
  .reflect-box,
  .practice-box,
  .verify-box,
  .tip-box {
    padding: 20px;
    border-radius: 12px;
    margin: 20px 0;
  }

  .learn-box {
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
    border-left: 5px solid #2196f3;
  }

  .reflect-box {
    background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
    border-left: 5px solid #ff9800;
  }

  .practice-box {
    background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
    border-left: 5px solid #9c27b0;
  }

  .verify-box {
    background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
    border-left: 5px solid #4caf50;
  }

  .tip-box {
    background: linear-gradient(135deg, #fff9e6 0%, #fff3cd 100%);
    border-left: 5px solid #ffc107;
  }

  .learn-box h4,
  .reflect-box h4,
  .practice-box h4,
  .verify-box h4,
  .tip-box h4 {
    margin-top: 0;
    margin-bottom: 10px;
  }

  /* Sections */
  section {
    margin-bottom: 50px;
  }

  section h2 {
    color: #333;
    margin-bottom: 20px;
    font-size: 1.8em;
  }

  section h3 {
    color: #555;
    margin-bottom: 15px;
  }

  section p {
    color: #555;
    line-height: 1.8;
    margin-bottom: 15px;
  }

  section ul,
  section ol {
    margin-left: 25px;
    margin-bottom: 15px;
  }

  section li {
    color: #555;
    margin-bottom: 8px;
    line-height: 1.6;
  }

  /* Code Blocks */
  pre {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 20px;
    border-radius: 10px;
    overflow-x: auto;
    margin: 15px 0;
  }

  code {
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
  }

  :not(pre) > code {
    background: #f0f0f0;
    padding: 2px 6px;
    border-radius: 4px;
    color: #e83e8c;
  }

  /* Tools Grid */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin: 30px 0;
  }

  .tool-card {
    background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
    padding: 25px;
    border-radius: 15px;
    text-align: center;
  }

  .tool-number {
    display: inline-block;
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 50%;
    line-height: 50px;
    font-size: 1.5em;
    font-weight: bold;
    margin-bottom: 15px;
  }

  .tool-card h3 {
    color: #667eea;
    margin-bottom: 5px;
  }

  .tool-card p {
    color: #666;
    margin: 0;
  }

  /* Checklist */
  .checklist {
    background: #f8f9fa;
    padding: 25px;
    border-radius: 15px;
  }

  .checklist label {
    display: block;
    padding: 12px;
    margin-bottom: 8px;
    background: white;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .checklist label:hover {
    background: #f0f0f0;
  }

  .checklist input[type="checkbox"] {
    margin-right: 10px;
  }

  /* Quiz */
  .quiz-form {
    background: #f8f9fa;
    padding: 30px;
    border-radius: 15px;
  }

  .question {
    margin-bottom: 25px;
    padding-bottom: 20px;
    border-bottom: 1px solid #ddd;
  }

  .question:last-child {
    border-bottom: none;
  }

  .question p {
    font-weight: 600;
    margin-bottom: 12px;
  }

  .question label {
    display: block;
    padding: 10px;
    margin-bottom: 8px;
    background: white;
    border-radius: 8px;
    cursor: pointer;
  }

  .question input[type="radio"] {
    margin-right: 10px;
  }

  .quiz-submit {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    padding: 15px 40px;
    border-radius: 25px;
    font-size: 1.1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
  }

  .quiz-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
  }

  .quiz-result {
    margin-top: 20px;
    padding: 20px;
    border-radius: 10px;
    text-align: center;
    font-weight: 600;
    display: none;
  }

  .quiz-result.pass {
    background: #d4edda;
    color: #155724;
    display: block;
  }

  .quiz-result.fail {
    background: #f8d7da;
    color: #721c24;
    display: block;
  }

  /* Level Navigation */
  .level-nav {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-top: 50px;
    padding-top: 30px;
    border-top: 2px solid #eee;
  }

  .level-nav .nav-btn {
    padding: 12px 24px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    text-decoration: none;
    border-radius: 12px;
    font-weight: 500;
    transition: all 0.3s;
  }

  .level-nav .nav-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.3);
  }

  /* Dark mode */
  :global(body.dark-mode) header h1 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .subtitle {
    color: #a8dadc;
  }

  :global(body.dark-mode) .meta,
  :global(body.dark-mode) .reading-time-badge {
    color: #c0c0c0;
  }

  :global(body.dark-mode) section h2 {
    color: #a8dadc;
  }

  :global(body.dark-mode) section h3 {
    color: #c0c0c0;
  }

  :global(body.dark-mode) section p,
  :global(body.dark-mode) section li {
    color: #c0c0c0;
  }

  :global(body.dark-mode) .toc-section {
    background: linear-gradient(135deg, #16213e 0%, #1a1a2e 100%);
  }

  :global(body.dark-mode) .toc-list a {
    color: #c0c0c0;
  }

  :global(body.dark-mode) .toc-list a:hover {
    background: rgba(168, 218, 220, 0.1);
    color: #a8dadc;
  }

  :global(body.dark-mode) .question label,
  :global(body.dark-mode) .checklist label {
    background: #2a2a4a;
    color: #c0c0c0;
  }

  :global(body.dark-mode) .quiz-form {
    background: #2a2a4a;
  }

  /* Responsive */
  @media (max-width: 768px) {
    header h1 {
      font-size: 1.8em;
    }

    .subtitle {
      font-size: 1.1em;
    }

    .tools-grid {
      grid-template-columns: 1fr;
    }

    .level-nav {
      flex-direction: column;
    }

    .level-nav .nav-btn {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  // Quiz functionality
  const quizForm = document.getElementById('quiz');
  const quizResult = document.getElementById('quizResult');

  const answers = {
    q1: 'b',
    q2: 'b',
    q3: 'b',
    q4: 'b'
  };

  if (quizForm && quizResult) {
    quizForm.addEventListener('submit', (e: Event) => {
      e.preventDefault();

      let score = 0;
      let total = Object.keys(answers).length;

      for (const [question, correctAnswer] of Object.entries(answers)) {
        const selected = document.querySelector(`input[name="${question}"]:checked`) as HTMLInputElement;
        if (selected && selected.value === correctAnswer) {
          score++;
        }
      }

      const percentage = (score / total) * 100;

      quizResult.className = 'quiz-result';
      if (percentage >= 75) {
        quizResult.classList.add('pass');
        quizResult.textContent = `🎉 Great job! You scored ${score}/${total} (${percentage}%)`;
      } else {
        quizResult.classList.add('fail');
        quizResult.textContent = `Keep practicing! You scored ${score}/${total} (${percentage}%). Try again!`;
      }
    });
  }

  // Smooth scroll for TOC links
  document.querySelectorAll('.toc-list a').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      if (href && href.startsWith('#')) {
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>
