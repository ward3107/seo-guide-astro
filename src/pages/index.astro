---
import Layout from '../layouts/Layout.astro';
import LevelCard from '../components/LevelCard.astro';

const base = import.meta.env.BASE_URL;

const levels = [
  {
    level: 1,
    title: 'SEO Basics',
    description: 'Content & Structure - Learn the foundational HTML elements that make websites search-friendly.',
    icon: '📘',
    href: `${base}/level1`,
    topicCount: '13 Topics + Quiz',
    topics: [
      'What is SEO & GEO?',
      'The Library Analogy',
      'The 5 Essential Tools',
      'Tool #1: The Title Tag',
      'Tool #2: The H1 Heading',
      'Tool #3: Links (Anchor Tags)',
      'Tool #4: Alt Attributes',
      'Tool #5: Schema Markup',
      'Search Intent: The "Why"',
      'How to View Source Code',
      'Practice Checklist',
      'Why Companies Hire Coders',
      'Off-Page SEO Basics'
    ]
  },
  {
    level: 2,
    title: 'Technical SEO',
    description: 'Robots, Speed & Status Codes - Master the technical infrastructure that powers search rankings.',
    icon: '🛠️',
    href: `${base}/level2`,
    topicCount: '10 Topics + Quiz',
    topics: [
      'Introduction to Technical SEO',
      'The Security Guard (robots.txt)',
      'The Table of Contents (XML Sitemaps)',
      'The Bot\'s Language (Status Codes)',
      'Speed & Performance Basics',
      'Core Web Vitals Metrics',
      'LCP, FID, CLS Explained',
      'Technical Audit Checklist',
      'Deep Dive Questions'
    ]
  },
  {
    level: 3,
    title: 'Advanced GEO',
    description: 'AI Optimization & Schema - Future-proof your content for AI-driven search experiences.',
    icon: '🤖',
    href: `${base}/level3`,
    topicCount: '9 Topics + Quiz',
    topics: [
      'SEO vs. GEO: The Big Shift',
      'Pillar 1: Facts Over Fluff',
      'Pillar 2: Schema for Trust',
      'Pillar 3: AI-Ready Structure',
      'Entity Optimization',
      'E-E-A-T: The Trust Framework',
      'GEO Audit Checklist',
      'Knowledge Graph & Entities',
      'Portfolio Completion'
    ]
  },
  {
    level: 4,
    title: 'Authority & Channels',
    description: 'Off-Page & Local SEO - Build authority through backlinks, reviews, local presence, and social channels.',
    icon: '🌐',
    href: `${base}/level4`,
    topicCount: '6 Modules + Mini-Quizzes',
    topics: [
      'Off-Page SEO Fundamentals',
      'Local SEO & Google Business Profile',
      'Reviews & Reputation Management',
      'Video SEO (YouTube Optimization)',
      'Social Search Optimization',
      'Authority Building Capstone'
    ]
  }
];
---

<Layout title="Waseem | English Teacher & Full-Stack SEO Developer">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>Hi, I'm Waseem 👋</h1>
      <p class="hero-subtitle">English Teacher & Full-Stack Developer</p>
      <p class="hero-description">
        I help businesses build digital experiences that are both <strong>discoverable</strong> and
        <strong>AI-friendly</strong>.
      </p>
      <div class="skills" role="list" aria-label="Skills and expertise">
        <span class="skill-pill">HTML/CSS/JavaScript</span>
        <span class="skill-pill">Technical SEO</span>
        <span class="skill-pill">GEO & AI Optimization</span>
        <span class="skill-pill">Schema Markup</span>
        <span class="skill-pill">Performance Optimization</span>
        <span class="skill-pill">Content Strategy</span>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about">
    <h2>About Me</h2>
    <p>
      I'm a passionate developer based in Haifa, Israel, with a unique background in both
      education and technology. As an English teacher, I understand the importance of clear
      communication. As a developer, I know how to make technology work for you.
    </p>
    <p>
      My expertise lies in the intersection of <strong>SEO</strong> (Search Engine Optimization) and
      <strong>GEO</strong> (Generative Engine Optimization) - ensuring your content ranks well
      in traditional search engines and is properly understood by AI systems like ChatGPT.
    </p>
    <p>
      Whether you need a website optimized for search, content that AI engines can understand,
      or technical guidance on improving your digital presence, I'm here to help.
    </p>
  </section>

  <!-- About the Course Section -->
  <section class="about-course">
    <h2>About This Course</h2>
    <div class="course-grid">
      <div class="course-item">
        <span class="course-icon">🎯</span>
        <h3>Comprehensive Curriculum</h3>
        <p>Four progressive levels covering everything from basic HTML optimization to advanced AI-driven GEO strategies.</p>
      </div>
      <div class="course-item">
        <span class="course-icon">📚</span>
        <h3>Practical & Hands-On</h3>
        <p>Real examples, code snippets, checklists, and quizzes to reinforce your learning at each step.</p>
      </div>
      <div class="course-item">
        <span class="course-icon">🤖</span>
        <h3>Future-Proof Skills</h3>
        <p>Learn GEO (Generative Engine Optimization) to stay ahead as AI-powered search becomes the new standard.</p>
      </div>
      <div class="course-item">
        <span class="course-icon">💼</span>
        <h3>Career-Ready Knowledge</h3>
        <p>Skills that employers are actively seeking - SEO, technical optimization, and AI content strategy.</p>
      </div>
    </div>
    <div class="course-stats">
      <div class="stat">
        <span class="stat-number">4</span>
        <span class="stat-label">Progressive Levels</span>
      </div>
      <div class="stat">
        <span class="stat-number">38+</span>
        <span class="stat-label">Topics Covered</span>
      </div>
      <div class="stat">
        <span class="stat-number">40+</span>
        <span class="stat-label">Quiz Questions</span>
      </div>
      <div class="stat">
        <span class="stat-number">∞</span>
        <span class="stat-label">Lifetime Access</span>
      </div>
    </div>
  </section>

  <!-- Learning Levels Section -->
  <section class="levels-section" aria-labelledby="levels-title">
    <h2 id="levels-title">🎓 Learn SEO & GEO</h2>
    <p style="text-align: center; color: #666; margin-bottom: 40px; font-size: 1.1em;">
      Explore my comprehensive guides on Search Engine Optimization and Generative Engine Optimization.
      Click on any level to start learning!
    </p>

    <div class="cards-grid">
      {levels.map(levelData => (
        <LevelCard {...levelData} />
      ))}
    </div>
  </section>

  <!-- Quiz Options Section -->
  <section class="quiz-options" aria-labelledby="quiz-title">
    <h2 id="quiz-title">📝 Test Your Knowledge</h2>
    <p style="text-align: center; color: #666; margin-bottom: 30px; font-size: 1.1em;">
      Choose how you want to test your SEO & GEO skills
    </p>
    <div class="quiz-cards">
      <a href={`${base}/practice-mode`} class="quiz-card practice">
        <span class="quiz-icon">💡</span>
        <h3>Practice Mode</h3>
        <p>15 questions • Learn with hints • Immediate feedback</p>
        <span class="quiz-btn">Start Practice →</span>
      </a>
      <a href={`${base}/quick-quiz`} class="quiz-card quick">
        <span class="quiz-icon">⚡</span>
        <h3>Quick Quiz</h3>
        <p>5 questions • Random selection • 5 minutes</p>
        <span class="quiz-btn">Start Quick Quiz →</span>
      </a>
      <a href={`${base}/timed-challenge`} class="quiz-card timed">
        <span class="quiz-icon">⏱️</span>
        <h3>Timed Challenge</h3>
        <p>Race the clock • 40 questions • 3 difficulty modes</p>
        <span class="quiz-btn">Start Challenge →</span>
      </a>
      <a href={`${base}/final-test`} class="quiz-card full">
        <span class="quiz-icon">🏆</span>
        <h3>Final Exam</h3>
        <p>40 questions • All levels • Comprehensive</p>
        <span class="quiz-btn">Start Final Test →</span>
      </a>
    </div>
    <div class="certificate-cta">
      <p>🎓 Completed the course? <a href={`${base}/certificate`}>Get your Certificate</a></p>
    </div>
    <div class="progress-cta">
      <p>📊 Track your learning progress: <a href={`${base}/progress`}>View Progress Dashboard</a></p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section" aria-labelledby="cta-title">
    <h2 id="cta-title">Let's Work Together</h2>
    <p>
      Looking for a developer who understands both code and search optimization?
      I'd love to hear about your project!
    </p>
    <a href="https://wa.me/972534260632?text=Hi%20Waseem!%20I'm%20interested%20in%20working%20with%20you."
       target="_blank"
       rel="noopener noreferrer"
       class="cta-button">
      📧 Hire Me
    </a>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    text-align: center;
    padding: 60px 20px;
    background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
    border-radius: 20px;
    margin-bottom: 40px;
  }

  .hero h1 {
    font-size: 3em;
    margin-bottom: 10px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.3em;
    color: #667eea;
    margin-bottom: 20px;
    font-weight: 500;
  }

  .hero-description {
    font-size: 1.1em;
    color: #555;
    max-width: 600px;
    margin: 0 auto 30px;
    line-height: 1.7;
  }

  .hero-description strong {
    color: #667eea;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .skill-pill {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 8px 20px;
    border-radius: 25px;
    font-size: 0.9em;
    font-weight: 500;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
  }

  /* About Section */
  .about {
    background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
    padding: 40px;
    border-radius: 20px;
    margin-bottom: 40px;
  }

  .about h2 {
    color: #667eea;
    margin-bottom: 20px;
    font-size: 2em;
  }

  .about p {
    color: #555;
    line-height: 1.8;
    margin-bottom: 15px;
    font-size: 1.05em;
  }

  .about strong {
    color: #667eea;
    font-weight: 600;
  }

  /* About Course Section */
  .about-course {
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    padding: 50px 40px;
    border-radius: 20px;
    margin-bottom: 40px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  .about-course h2 {
    text-align: center;
    color: #667eea;
    font-size: 2em;
    margin-bottom: 40px;
  }

  .course-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
  }

  .course-item {
    text-align: center;
    padding: 25px 20px;
    background: white;
    border-radius: 15px;
    border: 2px solid transparent;
    transition: all 0.3s ease;
  }

  .course-item:hover {
    border-color: #667eea;
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(102, 126, 234, 0.15);
  }

  .course-icon {
    font-size: 2.5em;
    display: block;
    margin-bottom: 15px;
  }

  .course-item h3 {
    color: #333;
    margin: 0 0 12px 0;
    font-size: 1.2em;
  }

  .course-item p {
    color: #666;
    line-height: 1.6;
    font-size: 0.95em;
    margin: 0;
  }

  .course-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    padding-top: 30px;
    border-top: 2px solid #e9ecef;
  }

  .stat {
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 2.5em;
    font-weight: bold;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    display: block;
    color: #666;
    font-size: 0.9em;
    margin-top: 5px;
  }

  /* Quiz Options Section */
  .quiz-options {
    margin-bottom: 40px;
  }

  .quiz-options h2 {
    text-align: center;
    color: #333;
    font-size: 2.2em;
    margin-bottom: 10px;
  }

  .quiz-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin-top: 30px;
  }

  .quiz-card {
    display: block;
    background: white;
    border-radius: 20px;
    padding: 35px 30px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    border: 2px solid transparent;
    text-align: center;
  }

  .quiz-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  .quiz-card.quick {
    border-color: #667eea;
  }

  .quiz-card.quick:hover {
    border-color: #764ba2;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  }

  .quiz-card.timed {
    border-color: #ffc107;
  }

  .quiz-card.timed:hover {
    border-color: #ff9800;
    background: linear-gradient(135deg, rgba(255, 193, 7, 0.05) 0%, rgba(255, 152, 0, 0.05) 100%);
  }

  .quiz-card.practice {
    border-color: #20c997;
  }

  .quiz-card.practice:hover {
    border-color: #17a2b8;
    background: linear-gradient(135deg, rgba(32, 201, 151, 0.05) 0%, rgba(23, 162, 184, 0.05) 100%);
  }

  .quiz-card.full {
    border-color: #f093fb;
  }

  .quiz-card.full:hover {
    border-color: #f5576c;
    background: linear-gradient(135deg, rgba(240, 147, 251, 0.05) 0%, rgba(245, 87, 108, 0.05) 100%);
  }

  .quiz-icon {
    font-size: 3em;
    display: block;
    margin-bottom: 15px;
  }

  .quiz-card h3 {
    color: #333;
    margin: 0 0 10px 0;
    font-size: 1.5em;
  }

  .quiz-card p {
    color: #666;
    margin: 0 0 20px 0;
    font-size: 1em;
  }

  .quiz-btn {
    display: inline-block;
    padding: 12px 30px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1em;
    transition: all 0.3s ease;
  }

  .quiz-card.quick .quiz-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .quiz-card.timed .quiz-btn {
    background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
    color: white;
  }

  .quiz-card.practice .quiz-btn {
    background: linear-gradient(135deg, #20c997 0%, #17a2b8 100%);
    color: white;
  }

  .quiz-card.full .quiz-btn {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
  }

  .quiz-card:hover .quiz-btn {
    transform: scale(1.05);
  }

  .certificate-cta {
    text-align: center;
    margin-top: 30px;
    padding: 20px;
    background: linear-gradient(135deg, #fff9e6 0%, #fff3cd 100%);
    border-radius: 15px;
  }

  .certificate-cta p {
    font-size: 1.1em;
    color: #856404;
    margin: 0;
  }

  .certificate-cta a {
    color: #667eea;
    font-weight: 600;
    text-decoration: underline;
  }

  .certificate-cta a:hover {
    color: #764ba2;
  }

  .progress-cta {
    text-align: center;
    margin-top: 20px;
    padding: 20px;
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
    border-radius: 15px;
  }

  .progress-cta p {
    font-size: 1.1em;
    color: #0d47a1;
    margin: 0;
  }

  .progress-cta a {
    color: #667eea;
    font-weight: 600;
    text-decoration: underline;
  }

  .progress-cta a:hover {
    color: #764ba2;
  }

  /* Levels Section */
  .levels-section {
    margin-bottom: 40px;
  }

  .levels-section h2 {
    text-align: center;
    color: #333;
    font-size: 2.2em;
    margin-bottom: 10px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin-top: 30px;
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 50px;
    border-radius: 20px;
    text-align: center;
    margin-bottom: 40px;
  }

  .cta-section h2 {
    margin-bottom: 15px;
    font-size: 2em;
  }

  .cta-section p {
    font-size: 1.1em;
    margin-bottom: 25px;
    opacity: 0.95;
  }

  .cta-button {
    display: inline-block;
    padding: 15px 40px;
    background: white;
    color: #667eea;
    text-decoration: none;
    border-radius: 30px;
    font-weight: 600;
    font-size: 1.1em;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
  }

  /* Final Test CTA Section */
  .final-test-cta {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    padding: 50px 40px;
    border-radius: 20px;
    text-align: center;
    margin-bottom: 40px;
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.12);
  }

  .final-test-cta h2 {
    color: #667eea;
    font-size: 2em;
    margin-bottom: 15px;
  }

  .final-test-cta p {
    color: #555;
    font-size: 1.1em;
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto 25px;
  }

  .test-features {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 30px;
  }

  .feature {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 8px 18px;
    border-radius: 20px;
    font-size: 0.9em;
    font-weight: 500;
  }

  .final-test-btn {
    display: inline-block;
    padding: 18px 50px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.15em;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
    transition: all 0.3s ease;
  }

  .final-test-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
  }

  /* Dark mode overrides */
  :global(body.dark-mode) .hero h1 {
    background: linear-gradient(135deg, #a8dadc 0%, #f093fb 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  :global(body.dark-mode) .hero-subtitle {
    color: #a8dadc;
  }

  :global(body.dark-mode) .hero-description {
    color: #c0c0c0;
  }

  :global(body.dark-mode) .about {
    background: linear-gradient(180deg, #16213e 0%, #1a1a2e 100%);
  }

  :global(body.dark-mode) .about h2 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .about p {
    color: #c0c0c0;
  }

  :global(body.dark-mode) .about-course {
    background: linear-gradient(135deg, #16213e 0%, #1a1a2e 100%);
  }

  :global(body.dark-mode) .about-course h2 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .course-item {
    background: #252540;
  }

  :global(body.dark-mode) .course-item h3 {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .course-item p {
    color: #b0b0b0;
  }

  :global(body.dark-mode) .course-stats {
    border-top-color: #3a3a5a;
  }

  :global(body.dark-mode) .stat-label {
    color: #b0b0b0;
  }

  :global(body.dark-mode) .levels-section h2 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .cta-section {
    background: linear-gradient(135deg, #533483 0%, #6a4c9c 100%);
  }

  :global(body.dark-mode) .final-test-cta {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }

  :global(body.dark-mode) .final-test-cta h2 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .final-test-cta p {
    color: #c0c0c0;
  }

  :global(body.dark-mode) .quiz-options h2 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .quiz-card {
    background: #252540;
  }

  :global(body.dark-mode) .quiz-card h3 {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .quiz-card p {
    color: #b0b0b0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2em;
    }

    .hero-subtitle {
      font-size: 1.1em;
    }

    .hero-description {
      font-size: 1em;
    }

    .about {
      padding: 25px;
    }

    .about h2 {
      font-size: 1.5em;
    }

    .levels-section h2 {
      font-size: 1.5em;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .cta-section {
      padding: 30px 20px;
    }

    .cta-section h2 {
      font-size: 1.5em;
    }

    .cta-button {
      padding: 12px 30px;
      font-size: 1em;
    }
  }
</style>
