---
import Layout from '../layouts/Layout.astro';
import LevelCard from '../components/LevelCard.astro';

const levels = [
  {
    level: 1,
    title: 'SEO Basics',
    description: 'Content & Structure - Learn the foundational HTML elements that make websites search-friendly.',
    icon: '📘',
    href: '/level1',
    topicCount: '13 Topics + Quiz',
    topics: [
      'What is SEO & GEO?',
      'The Library Analogy',
      'The 5 Essential Tools',
      'Tool #1: The Title Tag',
      'Tool #2: The H1 Heading',
      'Tool #3: Links (Anchor Tags)',
      'Tool #4: Alt Attributes',
      'Tool #5: Schema Markup',
      'Search Intent: The "Why"',
      'How to View Source Code',
      'Practice Checklist',
      'Why Companies Hire Coders',
      'Off-Page SEO Basics'
    ]
  },
  {
    level: 2,
    title: 'Technical SEO',
    description: 'Robots, Speed & Status Codes - Master the technical infrastructure that powers search rankings.',
    icon: '🛠️',
    href: '/level2',
    topicCount: '10 Topics + Quiz',
    topics: [
      'Introduction to Technical SEO',
      'The Security Guard (robots.txt)',
      'The Table of Contents (XML Sitemaps)',
      'The Bot\'s Language (Status Codes)',
      'Speed & Performance Basics',
      'Core Web Vitals Metrics',
      'LCP, FID, CLS Explained',
      'Technical Audit Checklist',
      'Deep Dive Questions'
    ]
  },
  {
    level: 3,
    title: 'Advanced GEO',
    description: 'AI Optimization & Schema - Future-proof your content for AI-driven search experiences.',
    icon: '🤖',
    href: '/level3',
    topicCount: '9 Topics + Quiz',
    topics: [
      'SEO vs. GEO: The Big Shift',
      'Pillar 1: Facts Over Fluff',
      'Pillar 2: Schema for Trust',
      'Pillar 3: AI-Ready Structure',
      'Entity Optimization',
      'E-E-A-T: The Trust Framework',
      'GEO Audit Checklist',
      'Knowledge Graph & Entities',
      'Portfolio Completion'
    ]
  },
  {
    level: 4,
    title: 'Authority & Channels',
    description: 'Off-Page & Local SEO - Build authority through backlinks, reviews, local presence, and social channels.',
    icon: '🌐',
    href: '/level4',
    topicCount: '6 Modules + Mini-Quizzes',
    topics: [
      'Off-Page SEO Fundamentals',
      'Local SEO & Google Business Profile',
      'Reviews & Reputation Management',
      'Video SEO (YouTube Optimization)',
      'Social Search Optimization',
      'Authority Building Capstone'
    ]
  }
];
---

<Layout title="Waseem | English Teacher & Full-Stack SEO Developer">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>Hi, I'm Waseem 👋</h1>
      <p class="hero-subtitle">English Teacher & Full-Stack Developer</p>
      <p class="hero-description">
        I help businesses build digital experiences that are both <strong>discoverable</strong> and
        <strong>AI-friendly</strong>.
      </p>
      <div class="skills" role="list" aria-label="Skills and expertise">
        <span class="skill-pill">HTML/CSS/JavaScript</span>
        <span class="skill-pill">Technical SEO</span>
        <span class="skill-pill">GEO & AI Optimization</span>
        <span class="skill-pill">Schema Markup</span>
        <span class="skill-pill">Performance Optimization</span>
        <span class="skill-pill">Content Strategy</span>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about">
    <h2>About Me</h2>
    <p>
      I'm a passionate developer based in Haifa, Israel, with a unique background in both
      education and technology. As an English teacher, I understand the importance of clear
      communication. As a developer, I know how to make technology work for you.
    </p>
    <p>
      My expertise lies in the intersection of <strong>SEO</strong> (Search Engine Optimization) and
      <strong>GEO</strong> (Generative Engine Optimization) - ensuring your content ranks well
      in traditional search engines and is properly understood by AI systems like ChatGPT.
    </p>
    <p>
      Whether you need a website optimized for search, content that AI engines can understand,
      or technical guidance on improving your digital presence, I'm here to help.
    </p>
  </section>

  <!-- Learning Levels Section -->
  <section class="levels-section" aria-labelledby="levels-title">
    <h2 id="levels-title">🎓 Learn SEO & GEO</h2>
    <p style="text-align: center; color: #666; margin-bottom: 40px; font-size: 1.1em;">
      Explore my comprehensive guides on Search Engine Optimization and Generative Engine Optimization.
      Click on any level to start learning!
    </p>

    <div class="cards-grid">
      {levels.map(levelData => (
        <LevelCard {...levelData} />
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section" aria-labelledby="cta-title">
    <h2 id="cta-title">Let's Work Together</h2>
    <p>
      Looking for a developer who understands both code and search optimization?
      I'd love to hear about your project!
    </p>
    <a href="https://wa.me/972534260632?text=Hi%20Waseem!%20I'm%20interested%20in%20working%20with%20you."
       target="_blank"
       rel="noopener noreferrer"
       class="cta-button">
      📧 Hire Me
    </a>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    text-align: center;
    padding: 60px 20px;
    background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
    border-radius: 20px;
    margin-bottom: 40px;
  }

  .hero h1 {
    font-size: 3em;
    margin-bottom: 10px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.3em;
    color: #667eea;
    margin-bottom: 20px;
    font-weight: 500;
  }

  .hero-description {
    font-size: 1.1em;
    color: #555;
    max-width: 600px;
    margin: 0 auto 30px;
    line-height: 1.7;
  }

  .hero-description strong {
    color: #667eea;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .skill-pill {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 8px 20px;
    border-radius: 25px;
    font-size: 0.9em;
    font-weight: 500;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
  }

  /* About Section */
  .about {
    background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
    padding: 40px;
    border-radius: 20px;
    margin-bottom: 40px;
  }

  .about h2 {
    color: #667eea;
    margin-bottom: 20px;
    font-size: 2em;
  }

  .about p {
    color: #555;
    line-height: 1.8;
    margin-bottom: 15px;
    font-size: 1.05em;
  }

  .about strong {
    color: #667eea;
    font-weight: 600;
  }

  /* Levels Section */
  .levels-section {
    margin-bottom: 40px;
  }

  .levels-section h2 {
    text-align: center;
    color: #333;
    font-size: 2.2em;
    margin-bottom: 10px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin-top: 30px;
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 50px;
    border-radius: 20px;
    text-align: center;
    margin-bottom: 40px;
  }

  .cta-section h2 {
    margin-bottom: 15px;
    font-size: 2em;
  }

  .cta-section p {
    font-size: 1.1em;
    margin-bottom: 25px;
    opacity: 0.95;
  }

  .cta-button {
    display: inline-block;
    padding: 15px 40px;
    background: white;
    color: #667eea;
    text-decoration: none;
    border-radius: 30px;
    font-weight: 600;
    font-size: 1.1em;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
  }

  /* Dark mode overrides */
  :global(body.dark-mode) .hero h1 {
    background: linear-gradient(135deg, #a8dadc 0%, #f093fb 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  :global(body.dark-mode) .hero-subtitle {
    color: #a8dadc;
  }

  :global(body.dark-mode) .hero-description {
    color: #c0c0c0;
  }

  :global(body.dark-mode) .about {
    background: linear-gradient(180deg, #16213e 0%, #1a1a2e 100%);
  }

  :global(body.dark-mode) .about h2 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .about p {
    color: #c0c0c0;
  }

  :global(body.dark-mode) .levels-section h2 {
    color: #a8dadc;
  }

  :global(body.dark-mode) .cta-section {
    background: linear-gradient(135deg, #533483 0%, #6a4c9c 100%);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2em;
    }

    .hero-subtitle {
      font-size: 1.1em;
    }

    .hero-description {
      font-size: 1em;
    }

    .about {
      padding: 25px;
    }

    .about h2 {
      font-size: 1.5em;
    }

    .levels-section h2 {
      font-size: 1.5em;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .cta-section {
      padding: 30px 20px;
    }

    .cta-section h2 {
      font-size: 1.5em;
    }

    .cta-button {
      padding: 12px 30px;
      font-size: 1em;
    }
  }
</style>
