---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Quick Quiz | Waseem's SEO Guide">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={`${base}/`}>Home</a></li>
      <li><a href={`${base}/final-test`}>Final Test</a></li>
      <li aria-current="page">Quick Quiz</li>
    </ol>
  </nav>

  <header>
    <span class="badge">⚡ QUICK CHECK</span>
    <h1>5-Minute SEO Quiz</h1>
    <p class="subtitle">Test your SEO knowledge fast - Random 5 questions, instant results</p>
  </header>

  <section class="quiz-intro">
    <h2>🎯 About This Quiz</h2>
    <div class="intro-grid">
      <div class="intro-card">
        <span class="intro-icon">⚡</span>
        <h3>5 Questions Only</h3>
        <p>Complete in under 5 minutes</p>
      </div>
      <div class="intro-card">
        <span class="intro-icon">🎲</span>
        <h3>Random Selection</h3>
        <p>Different questions each time</p>
      </div>
      <div class="intro-card">
        <span class="intro-icon">📊</span>
        <h3>Instant Results</h3>
        <p>Get your score immediately</p>
      </div>
      <div class="intro-card">
        <span class="intro-icon">🔄</span>
        <h3>Unlimited Attempts</h3>
        <p>Practice as much as you want</p>
      </div>
    </div>
  </section>

  <div class="quick-quiz-container" id="quickQuiz" role="region" aria-label="Quick Quiz">
    <!-- Skeleton Loading -->
    <div class="quiz-skeleton" id="quizSkeleton" aria-hidden="true">
      <div class="skeleton skeleton-card" style="height: 200px; margin-bottom: 20px;"></div>
      <div class="skeleton skeleton-card" style="height: 200px; margin-bottom: 20px;"></div>
      <div class="skeleton skeleton-card" style="height: 200px; margin-bottom: 20px;"></div>
      <div class="skeleton skeleton-card" style="height: 200px; margin-bottom: 20px;"></div>
      <div class="skeleton skeleton-card" style="height: 200px; margin-bottom: 20px;"></div>
    </div>

    <form class="quiz-form" id="quickQuizForm" aria-label="Quiz questions" style="display: none;">
      <!-- Questions will be injected by JavaScript -->
    </form>

    <div class="quiz-actions">
      <button type="button" class="submit-btn" id="submitQuizBtn" aria-label="Submit your answers and see results">Submit Quiz</button>
    </div>

    <div class="quiz-actions-secondary">
      <button type="button" class="new-quiz-btn" id="newQuizBtn" aria-label="Generate new random questions">🔄 New Questions</button>
    </div>

    <div class="quiz-result" id="quizResult" role="alert" aria-live="polite" style="display: none;">
      <div class="result-content">
        <div class="result-score" role="status" aria-live="polite"></div>
        <div class="result-message"></div>
        <button class="retake-btn" id="retakeBtn" aria-label="Retake the quiz with new questions">Try Again</button>
        <a href={`${base}/final-test`} class="full-test-btn" aria-label="Proceed to the full 40-question test">Take Full 40-Question Test →</a>
      </div>
    </div>
  </div>

  <div class="back-home">
    <button id="backToStartBtn" class="back-start-btn">← Back to Start</button>
  </div>
</Layout>

<style is:inline>
  .quiz-intro {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .quiz-intro h2 {
    color: #667eea;
    margin-bottom: 25px;
    text-align: center;
    font-size: 1.8em;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }

  .intro-card {
    background: white;
    border-radius: 15px;
    padding: 25px;
    text-align: center;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
  }

  .intro-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.2);
  }

  .intro-icon {
    display: block;
    font-size: 2.5em;
    margin-bottom: 15px;
  }

  .intro-card h3 {
    margin: 0 0 10px 0;
    color: #333;
    font-size: 1.1em;
  }

  .intro-card p {
    margin: 0;
    color: #666;
    font-size: 0.95em;
    line-height: 1.5;
  }

  .quick-quiz-container {
    max-width: 800px;
    margin: 0 auto 40px;
  }

  .quiz-form {
    margin-bottom: 20px;
  }

  .question-card {
    background: white;
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 25px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    border: 2px solid #e8e8f0;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .question-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  }

  .question-card:hover {
    box-shadow: 0 12px 40px rgba(102, 126, 234, 0.15);
    transform: translateY(-2px);
  }

  .question-number {
    display: inline-block;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 8px 20px;
    border-radius: 25px;
    font-size: 0.85em;
    font-weight: 700;
    margin-bottom: 20px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .question-text {
    font-size: 1.25em;
    color: #2d2d3a;
    margin: 0 0 25px 0;
    line-height: 1.6;
    font-weight: 600;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .option-label {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 22px;
    border: 2px solid #e0e5f0;
    border-radius: 14px;
    cursor: pointer;
    transition: all 0.25s ease;
    background: #fafbfc;
    position: relative;
  }

  .option-label:hover {
    border-color: #667eea;
    background: #f0f4ff;
    transform: translateX(5px);
  }

  .option-label input:checked + .option-letter {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    transform: scale(1.1);
  }

  .option-label input:checked ~ .option-text {
    color: #667eea;
    font-weight: 600;
  }

  .option-label:has(input:checked) {
    border-color: #667eea;
    background: #f0f4ff;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.2);
  }

  .option-letter {
    background: #e8edf5;
    color: #555;
    width: 38px;
    height: 38px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9em;
    font-weight: 700;
    flex-shrink: 0;
    transition: all 0.25s ease;
  }

  .option-text {
    flex: 1;
    color: #444;
    font-size: 1.05em;
    line-height: 1.5;
  }

  .option-label input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .quiz-actions {
    display: flex;
    justify-content: center;
    padding: 25px 0 10px;
  }

  .quiz-actions-secondary {
    display: flex;
    justify-content: center;
    margin-top: 10px;
  }

  .explanation {
    margin-top: 15px;
    padding: 15px 18px;
    background: linear-gradient(135deg, #fff9e6 0%, #fff3cd 100%);
    border-left: 4px solid #ffc107;
    border-radius: 8px;
    display: none;
    gap: 10px;
    align-items: start;
  }

  .explanation.show {
    display: flex;
  }

  .explanation-icon {
    font-size: 1.2em;
  }

  .explanation-text {
    flex: 1;
    color: #666;
    line-height: 1.6;
  }

  .quiz-actions {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  .submit-btn, .new-quiz-btn {
    padding: 15px 40px;
    border: none;
    border-radius: 50px;
    font-size: 1.1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .submit-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
  }

  .submit-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
  }

  .new-quiz-btn {
    background: #f8f9fa;
    color: #667eea;
    border: 2px solid #667eea;
  }

  .new-quiz-btn:hover {
    background: #667eea;
    color: white;
  }

  .quiz-result {
    background: white;
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .result-score {
    font-size: 4em;
    font-weight: bold;
    margin-bottom: 10px;
  }

  .result-score.perfect {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .result-score.good {
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .result-score.needs-work {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .result-message {
    font-size: 1.4em;
    margin-bottom: 30px;
    color: #333;
  }

  .retake-btn, .full-test-btn {
    display: inline-block;
    padding: 15px 40px;
    border-radius: 50px;
    font-size: 1em;
    font-weight: 600;
    text-decoration: none;
    margin: 0 10px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .retake-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
  }

  .full-test-btn {
    background: #f8f9fa;
    color: #667eea;
    border: 2px solid #667eea;
  }

  .retake-btn:hover, .full-test-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
  }

  .back-home {
    text-align: center;
    margin: 40px 0;
  }

  .back-home a,
  .back-start-btn {
    display: inline-block;
    padding: 15px 30px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    text-decoration: none;
    border: none;
    border-radius: 50px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
    font-size: 1em;
  }

  .back-home a:hover,
  .back-start-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
  }

  .option-label.correct {
    border-color: #28a745 !important;
    background: #d4edda !important;
  }

  .option-label.incorrect {
    border-color: #dc3545 !important;
    background: #f8d7da !important;
  }

  /* Dark mode */
  :global(body.dark-mode) .quiz-intro {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }

  :global(body.dark-mode) .intro-card {
    background: #252540;
  }

  :global(body.dark-mode) .intro-card h3 {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .intro-card p {
    color: #b0b0b0;
  }

  :global(body.dark-mode) .question-card {
    background: #252540;
    border-color: #3a3a5a;
  }

  :global(body.dark-mode) .question-text {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .option-label {
    border-color: #3a3a5a;
    background: #2a2a4a;
  }

  :global(body.dark-mode) .option-label:hover {
    border-color: #667eea;
    background: #3a3a5a;
  }

  :global(body.dark-mode) .option-text {
    color: #b0b0b0;
  }

  :global(body.dark-mode) .option-letter {
    background: #3a3a5a;
    color: #a0a0c0;
  }

  :global(body.dark-mode) .quiz-result {
    background: #252540;
  }

  :global(body.dark-mode) .result-message {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .question-card:has(.option-label:where(input:checked)) {
    border-color: #667eea;
    background: #2a2a4a;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .question-card {
      padding: 22px;
      border-radius: 16px;
    }

    .question-text {
      font-size: 1.1em;
    }

    .option-label {
      padding: 15px 18px;
    }

    .option-letter {
      width: 34px;
      height: 34px;
      font-size: 0.85em;
    }

    .option-text {
      font-size: 1em;
    }

    .quiz-actions {
      padding: 20px 0 10px;
    }

    .submit-btn, .new-quiz-btn {
      width: 100%;
    }

    .retake-btn, .full-test-btn {
      display: block;
      margin: 10px 0;
      width: 100%;
    }
  }
</style>

<script>
  // All questions pool
  const allQuestions = [
    {
      q: "What does SEO stand for?",
      options: ["Search Engine Optimization", "Site Enhancement Organization", "Social Email Outreach", "System Entry Operation"],
      correct: "a",
      explanation: "SEO stands for Search Engine Optimization - optimizing websites to rank higher in search results."
    },
    {
      q: "Which HTML tag is MOST important for SEO?",
      options: ["<title> tag", "<meta> tag", "<div> tag", "<span> tag"],
      correct: "a",
      explanation: "The <title> tag appears in search results and browser tabs - it's crucial for SEO."
    },
    {
      q: "What is the purpose of robots.txt?",
      options: ["Control which pages search bots can crawl", "Speed up website", "Block all visitors", "Create sitemaps"],
      correct: "a",
      explanation: "robots.txt tells search crawlers which pages they can or cannot access on your site."
    },
    {
      q: "What is GEO (Generative Engine Optimization)?",
      options: ["Optimizing for AI-powered search engines", "Creating geographic content", "Auto-generating content", "Location optimization"],
      correct: "a",
      explanation: "GEO optimizes content so AI systems like ChatGPT and Google's SGE can understand and cite it."
    },
    {
      q: "What is the difference between dofollow and nofollow links?",
      options: ["Dofollow passes SEO value, nofollow doesn't", "Nofollow is better", "No difference", "Dofollow is from social media"],
      correct: "a",
      explanation: "Dofollow links pass link equity (SEO value), while nofollow tells search engines not to count the link."
    },
    {
      q: "How many H1 tags should a page have?",
      options: ["One", "Two or three", "As many as you want", "Zero"],
      correct: "a",
      explanation: "Each page should have exactly one H1 tag describing the main topic."
    },
    {
      q: "What does a 404 status code mean?",
      options: ["Page not found", "Server error", "Page moved", "Success"],
      correct: "a",
      explanation: "404 means the page doesn't exist. Fix 404s for good UX and SEO."
    },
    {
      q: "What is Schema markup?",
      options: ["Structured data helping search engines understand content", "Color scheme", "Database structure", "Programming language"],
      correct: "a",
      explanation: "Schema markup is structured data that helps search engines understand content better."
    },
    {
      q: "What is the meta description?",
      options: ["Brief summary for search results", "Main heading", "Keyword list", "Page title"],
      correct: "a",
      explanation: "The meta description is a 150-160 character summary that appears in search results."
    },
    {
      q: "What is LCP in Core Web Vitals?",
      options: ["Largest Contentful Paint - loading time", "Link Click Performance", "Last Content Published", "Local Cache Priority"],
      correct: "a",
      explanation: "LCP measures how long the largest content element takes to load."
    },
    {
      q: "What is E-E-A-T?",
      options: ["Experience, Expertise, Authoritativeness, Trustworthiness", "Engine, Engagement, Analytics", "Every Employee Acts Together", "Electronic Exchange Art"],
      correct: "a",
      explanation: "E-E-A-T is Google's framework for evaluating content quality."
    },
    {
      q: "What is anchor text?",
      options: ["Clickable text in a hyperlink", "Title tag text", "Meta description", "Alt text"],
      correct: "a",
      explanation: "Anchor text is the visible, clickable text in a hyperlink."
    },
    {
      q: "What is Google Business Profile for?",
      options: ["Local SEO and Google Maps", "International SEO", "Image optimization", "Video ranking"],
      correct: "a",
      explanation: "Google Business Profile is essential for local SEO - appearing in local pack and Maps results."
    },
    {
      q: "What is an XML sitemap?",
      options: ["File listing important pages for search engines", "Visual site map", "User database", "Backup file"],
      correct: "a",
      explanation: "An XML sitemap lists your important pages, helping search engines discover and crawl content."
    },
    {
      q: "What is keyword stuffing?",
      options: ["Overusing keywords unnaturally", "Researching keywords", "Natural keyword usage", "Meta keywords tag"],
      correct: "a",
      explanation: "Keyword stuffing is overusing keywords to manipulate rankings - it can hurt your SEO."
    }
  ];

  // Shuffle array function
  function shuffleArray<T>(array: T[]): T[] {
    const shuffled = [...array];
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
  }

  // Get 5 random questions
  function getRandomQuestions(): typeof allQuestions {
    return shuffleArray(allQuestions).slice(0, 5);
  }

  // Render quiz
  function renderQuiz(): void {
    const skeleton = document.getElementById('quizSkeleton');
    const form = document.getElementById('quickQuizForm') as HTMLFormElement;

    // Show skeleton, hide form temporarily
    if (skeleton) {
      skeleton.style.display = 'block';
      skeleton.setAttribute('aria-hidden', 'false');
    }
    if (form) {
      form.style.display = 'none';
    }

    // Small delay to show skeleton effect
    setTimeout(() => {
      const rawQuestions = getRandomQuestions();

      // Shuffle options for each question and update correct answer
      const questions = rawQuestions.map(q => {
      // Create array of option objects with their original letters
      const originalOptions = q.options.map((opt, idx) => ({
        text: opt,
        originalLetter: String.fromCharCode(97 + idx) // a, b, c, d...
      }));

      // Shuffle the options
      const shuffledOptions = shuffleArray(originalOptions);

      // Find where the correct answer ended up
      const originalCorrectIndex = q.correct.charCodeAt(0) - 97; // 0 for 'a', 1 for 'b', etc.
      const correctText = q.options[originalCorrectIndex];
      const newCorrectIndex = shuffledOptions.findIndex(opt => opt.text === correctText);
      const newCorrectLetter = String.fromCharCode(97 + newCorrectIndex); // new position letter

      return {
        ...q,
        options: shuffledOptions.map(opt => opt.text),
        correct: newCorrectLetter
      };
    });

    const form = document.getElementById('quickQuizForm') as HTMLFormElement;

    form.innerHTML = questions.map((q, index) => `
      <div class="question-card" data-index="${index}" role="group" aria-labelledby="question-${index}-title">
        <span class="question-number">Question ${index + 1}</span>
        <p class="question-text" id="question-${index}-title">${q.q}</p>
        <div class="options" role="radiogroup" aria-label="Answer options for question ${index + 1}">
          ${q.options.map((opt: string, optIndex: number) => {
            const letter = String.fromCharCode(97 + optIndex);
            return `
              <label class="option-label">
                <input type="radio" name="q${index}" id="q${index}-${letter}" value="${letter}" data-correct="${q.correct}" aria-describedby="explanation-${index}">
                <span class="option-letter">${letter.toUpperCase()})</span>
                <span class="option-text">${opt}</span>
              </label>
            `;
          }).join('')}
        </div>
        <p class="explanation" id="explanation-${index}" data-for="q${index}" role="note" aria-hidden="true">
          <span class="explanation-icon">💡</span>
          <span class="explanation-text">${q.explanation}</span>
        </p>
      </div>
    `).join('');

      // Store questions for scoring
      (form as any).dataset.questions = JSON.stringify(questions);

      // Hide skeleton and show form
      if (skeleton) {
        skeleton.style.display = 'none';
        skeleton.setAttribute('aria-hidden', 'true');
      }
      if (form) {
        form.style.display = 'block';
      }
    }, 300); // 300ms skeleton delay
  }

  // Initialize quiz
  renderQuiz();

  // Keyboard navigation support
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    // Only handle keyboard nav when quiz is active
    const quizForm = document.getElementById('quickQuizForm');
    if (!quizForm || quizForm.style.display === 'none') return;

    const focusedElement = document.activeElement as HTMLElement;
    const optionLabel = focusedElement?.closest('.option-label');

    if (optionLabel) {
      const allOptions = Array.from(optionLabel.parentElement?.querySelectorAll('.option-label') || []);
      const currentIndex = allOptions.indexOf(optionLabel);

      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        e.preventDefault();
        const nextIndex = (currentIndex + 1) % allOptions.length;
        (allOptions[nextIndex].querySelector('input') as HTMLInputElement)?.focus();
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault();
        const prevIndex = (currentIndex - 1 + allOptions.length) % allOptions.length;
        (allOptions[prevIndex].querySelector('input') as HTMLInputElement)?.focus();
      } else if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        (optionLabel.querySelector('input') as HTMLInputElement)?.click();
      }
    }
  });

  // New quiz button
  const newQuizBtn = document.getElementById('newQuizBtn');
  const retakeBtn = document.getElementById('retakeBtn');
  const submitQuizBtn = document.getElementById('submitQuizBtn');

  const refreshQuiz = () => {
    renderQuiz();
    (document.getElementById('quizResult') as HTMLElement).style.display = 'none';
    (document.getElementById('quickQuizForm') as HTMLElement).style.display = 'block';
    if (submitQuizBtn) submitQuizBtn.style.display = 'inline-block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  newQuizBtn?.addEventListener('click', refreshQuiz);
  retakeBtn?.addEventListener('click', refreshQuiz);

  // Back to Start button - reset quiz without leaving page
  const backToStartBtn = document.getElementById('backToStartBtn');
  backToStartBtn?.addEventListener('click', () => {
    refreshQuiz();
  });

  // Submit button click handler
  submitQuizBtn?.addEventListener('click', () => {
    const form = document.getElementById('quickQuizForm') as HTMLFormElement;
    form.dispatchEvent(new Event('submit', { cancelable: true }));
  });

  // Form submit
  const form = document.getElementById('quickQuizForm') as HTMLFormElement;
  form.addEventListener('submit', (e: Event) => {
    e.preventDefault();

    const formData = new FormData(form);
    const questionsData = (form as any).dataset.questions;
    if (!questionsData) {
      console.error('No questions stored in form dataset');
      return;
    }
    const questions = JSON.parse(questionsData);
    let correct = 0;

    questions.forEach((q: any, index: number) => {
      const selected = formData.get(`q${index}`);
      const card = form.querySelector(`[data-index="${index}"]`) as HTMLElement;

      // Skip if card doesn't exist
      if (!card) return;

      const inputs = card.querySelectorAll('input[type="radio"]');
      const explanation = card.querySelector('.explanation') as HTMLElement;

      // Reset and show correct/incorrect
      Array.from(card.querySelectorAll('.option-label')).forEach((label: Element) => {
        (label as HTMLElement).classList.remove('correct', 'incorrect');
      });

      Array.from(inputs).forEach((input: Element) => {
        const inputEl = input as HTMLInputElement;
        const label = inputEl.closest('.option-label') as HTMLElement;
        if (!label) return;
        if (inputEl.dataset.correct === inputEl.value) {
          label.classList.add('correct');
        } else if (inputEl.value === selected) {
          label.classList.add('incorrect');
        }
      });

      // Show explanation
      if (explanation) {
        explanation.classList.add('show');
      }

      if (selected === q.correct) {
        correct++;
      }
    });

    // Show results
    form.style.display = 'none';
    if (submitQuizBtn) submitQuizBtn.style.display = 'none';
    const resultDiv = document.getElementById('quizResult') as HTMLElement;
    resultDiv.style.display = 'block';

    const scoreDiv = resultDiv.querySelector('.result-score') as HTMLElement;
    const messageDiv = resultDiv.querySelector('.result-message') as HTMLElement;
    const percentage = (correct / 5) * 100;

    let scoreClass = 'needs-work';
    let message = '';

    if (percentage === 100) {
      scoreClass = 'perfect';
      message = '🎉 Perfect! You\'re an SEO expert!';
    } else if (percentage >= 80) {
      scoreClass = 'good';
      message = '👏 Great job! Strong SEO knowledge!';
    } else if (percentage >= 60) {
      scoreClass = 'good';
      message = '👍 Good effort! Keep learning.';
    } else {
      message = '📚 Keep studying! Review the levels and try again.';
    }

    scoreDiv.textContent = `${correct}/5`;
    scoreDiv.className = `result-score ${scoreClass}`;
    messageDiv.textContent = message;

    // Save progress to localStorage
    saveQuizProgress('quick-quiz', percentage);

    // Move focus to result for accessibility
    resultDiv.setAttribute('tabindex', '-1');
    resultDiv.focus();

    resultDiv.scrollIntoView({ behavior: 'smooth' });
  });

  // Save quiz progress to localStorage
  interface ProgressData {
    levels: any;
    quizzes: {
      quickQuiz: { taken: number; bestScore: number; history?: Array<{ date: string; score: number; total: number; correct: number }>; lastAttempt?: string };
      timedChallenge: { taken: number; bestScore: number; history?: any[]; lastAttempt?: string };
      practiceMode: { taken: number; bestScore: number; history?: any[]; lastAttempt?: string };
      finalTest: { taken: number; bestScore: number; history?: any[]; lastAttempt?: string };
    };
    achievements: string[];
    streak?: number;
    lastPracticeDate?: string;
  }

  function saveQuizProgress(quizId: string, score: number) {
    const storageKey = 'seoCourseProgress';
    const stored = localStorage.getItem(storageKey);
    let progress: ProgressData = stored ? JSON.parse(stored) : {
      levels: { level1: { completed: false, progress: 0 }, level2: { completed: false, progress: 0 }, level3: { completed: false, progress: 0 }, level4: { completed: false, progress: 0 } },
      quizzes: {
        quickQuiz: { taken: 0, bestScore: 0, history: [], lastAttempt: '' },
        timedChallenge: { taken: 0, bestScore: 0, history: [], lastAttempt: '' },
        practiceMode: { taken: 0, bestScore: 0, history: [], lastAttempt: '' },
        finalTest: { taken: 0, bestScore: 0, history: [], lastAttempt: '' }
      },
      achievements: [],
      streak: 0,
      lastPracticeDate: ''
    };

    // Map quizId to correct key (e.g., 'quick-quiz' -> 'quickQuiz')
    const quizKeyMap: Record<string, keyof ProgressData['quizzes']> = {
      'quick-quiz': 'quickQuiz',
      'timed-challenge': 'timedChallenge',
      'practice-mode': 'practiceMode',
      'final-test': 'finalTest'
    };
    const quizKey = quizKeyMap[quizId] || quizId as keyof typeof progress.quizzes;

    // Update quiz stats
    const quiz = progress.quizzes[quizKey];
    if (!quiz) return;
    quiz.taken++;
    if (score > quiz.bestScore) {
      quiz.bestScore = score;
    }

    // Save attempt to history
    if (!quiz.history) quiz.history = [];
    quiz.history.push({
      date: new Date().toISOString(),
      score: score,
      total: 5,
      correct: Math.round(score / 100 * 5)
    });

    // Keep only last 10 attempts
    if (quiz.history.length > 10) {
      quiz.history = quiz.history.slice(-10);
    }

    quiz.lastAttempt = new Date().toISOString();

    // Update streak
    const today = new Date().toDateString();
    if (progress.lastPracticeDate !== today) {
      const yesterday = new Date(Date.now() - 86400000).toDateString();
      if (progress.lastPracticeDate === yesterday) {
        progress.streak = (progress.streak || 0) + 1;
      } else if (progress.lastPracticeDate !== today) {
        progress.streak = 1;
      }
      progress.lastPracticeDate = today;
    }

    localStorage.setItem(storageKey, JSON.stringify(progress));
  }
</script>
