---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Quick Quiz | Waseem's SEO Guide">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={`${base}/`}>Home</a></li>
      <li><a href={`${base}/final-test`}>Final Test</a></li>
      <li aria-current="page">Quick Quiz</li>
    </ol>
  </nav>

  <header>
    <span class="badge">⚡ QUICK CHECK</span>
    <h1>5-Minute SEO Quiz</h1>
    <p class="subtitle">Test your SEO knowledge fast - Random 5 questions, instant results</p>
  </header>

  <section class="quiz-intro">
    <h2>🎯 About This Quiz</h2>
    <ul>
      <li>⚡ <strong>5 Questions Only</strong> - Complete in under 5 minutes</li>
      <li>🎲 <strong>Random Selection</strong> - Different questions each time</li>
      <li>📊 <strong>Instant Results</strong> - Get your score immediately</li>
      <li>🔄 <strong>Unlimited Attempts</strong> - Practice as much as you want</li>
    </ul>
  </section>

  <div class="quick-quiz-container" id="quickQuiz">
    <form class="quiz-form" id="quickQuizForm">
      <!-- Questions will be injected by JavaScript -->
    </form>

    <div class="quiz-actions">
      <button type="submit" class="submit-btn">Submit Quiz</button>
      <button type="button" class="new-quiz-btn" id="newQuizBtn">🔄 New Questions</button>
    </div>

    <div class="quiz-result" id="quizResult" style="display: none;">
      <div class="result-content">
        <div class="result-score"></div>
        <div class="result-message"></div>
        <button class="retake-btn" id="retakeBtn">Try Again</button>
        <a href={`${base}/final-test`} class="full-test-btn">Take Full 40-Question Test →</a>
      </div>
    </div>
  </div>

  <div class="back-home">
    <a href={`${base}/`}>← Back to Home</a>
  </div>
</Layout>

<style>
  .quiz-intro {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 30px;
  }

  .quiz-intro h2 {
    color: #667eea;
    margin-bottom: 20px;
  }

  .quiz-intro ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .quiz-intro li {
    padding: 12px 0;
    font-size: 1.05em;
    color: #555;
    border-bottom: 1px dashed #ddd;
  }

  .quiz-intro li:last-child {
    border-bottom: none;
  }

  .quick-quiz-container {
    max-width: 800px;
    margin: 0 auto 40px;
  }

  .question-card {
    background: white;
    border-radius: 16px;
    padding: 25px;
    margin-bottom: 20px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    border-left: 5px solid #667eea;
  }

  .question-number {
    display: inline-block;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 0.9em;
    font-weight: 600;
    margin-bottom: 15px;
  }

  .question-text {
    font-size: 1.15em;
    color: #333;
    margin: 0 0 20px 0;
    line-height: 1.6;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .option-label {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 15px 18px;
    border: 2px solid #e0e0e0;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .option-label:hover {
    border-color: #667eea;
    background: #f8f9ff;
  }

  .option-label input:checked + .option-letter {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .option-label input:checked ~ .option-text {
    color: #667eea;
    font-weight: 600;
  }

  .option-letter {
    background: #f0f0f0;
    color: #666;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85em;
    font-weight: bold;
    flex-shrink: 0;
  }

  .option-text {
    flex: 1;
  }

  .option-label input[type="radio"] {
    display: none;
  }

  .explanation {
    margin-top: 15px;
    padding: 15px 18px;
    background: linear-gradient(135deg, #fff9e6 0%, #fff3cd 100%);
    border-left: 4px solid #ffc107;
    border-radius: 8px;
    display: none;
    gap: 10px;
    align-items: start;
  }

  .explanation.show {
    display: flex;
  }

  .explanation-icon {
    font-size: 1.2em;
  }

  .explanation-text {
    flex: 1;
    color: #666;
    line-height: 1.6;
  }

  .quiz-actions {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  .submit-btn, .new-quiz-btn {
    padding: 15px 40px;
    border: none;
    border-radius: 50px;
    font-size: 1.1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .submit-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
  }

  .submit-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
  }

  .new-quiz-btn {
    background: #f8f9fa;
    color: #667eea;
    border: 2px solid #667eea;
  }

  .new-quiz-btn:hover {
    background: #667eea;
    color: white;
  }

  .quiz-result {
    background: white;
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .result-score {
    font-size: 4em;
    font-weight: bold;
    margin-bottom: 10px;
  }

  .result-score.perfect {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .result-score.good {
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .result-score.needs-work {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .result-message {
    font-size: 1.4em;
    margin-bottom: 30px;
    color: #333;
  }

  .retake-btn, .full-test-btn {
    display: inline-block;
    padding: 15px 40px;
    border-radius: 50px;
    font-size: 1em;
    font-weight: 600;
    text-decoration: none;
    margin: 0 10px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .retake-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
  }

  .full-test-btn {
    background: #f8f9fa;
    color: #667eea;
    border: 2px solid #667eea;
  }

  .retake-btn:hover, .full-test-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
  }

  .back-home {
    text-align: center;
    margin: 40px 0;
  }

  .back-home a {
    display: inline-block;
    padding: 15px 30px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
  }

  .back-home a:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
  }

  .option-label.correct {
    border-color: #28a745 !important;
    background: #d4edda !important;
  }

  .option-label.incorrect {
    border-color: #dc3545 !important;
    background: #f8d7da !important;
  }

  /* Dark mode */
  :global(body.dark-mode) .quiz-intro {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }

  :global(body.dark-mode) .quiz-intro li {
    color: #b0b0b0;
    border-bottom-color: #3a3a5a;
  }

  :global(body.dark-mode) .question-card {
    background: #252540;
  }

  :global(body.dark-mode) .question-text {
    color: #e0e0e0;
  }

  :global(body.dark-mode) .option-label {
    border-color: #3a3a5a;
    background: #2a2a4a;
  }

  :global(body.dark-mode) .option-label:hover {
    border-color: #667eea;
    background: #3a3a5a;
  }

  :global(body.dark-mode) .quiz-result {
    background: #252540;
  }

  :global(body.dark-mode) .result-message {
    color: #e0e0e0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .quiz-actions {
      flex-direction: column;
    }

    .submit-btn, .new-quiz-btn {
      width: 100%;
    }

    .retake-btn, .full-test-btn {
      display: block;
      margin: 10px 0;
      width: 100%;
    }
  }
</style>

<script>
  // All questions pool
  const allQuestions = [
    {
      q: "What does SEO stand for?",
      options: ["Search Engine Optimization", "Site Enhancement Organization", "Social Email Outreach", "System Entry Operation"],
      correct: "a",
      explanation: "SEO stands for Search Engine Optimization - optimizing websites to rank higher in search results."
    },
    {
      q: "Which HTML tag is MOST important for SEO?",
      options: ["<title> tag", "<meta> tag", "<div> tag", "<span> tag"],
      correct: "a",
      explanation: "The <title> tag appears in search results and browser tabs - it's crucial for SEO."
    },
    {
      q: "What is the purpose of robots.txt?",
      options: ["Control which pages search bots can crawl", "Speed up website", "Block all visitors", "Create sitemaps"],
      correct: "a",
      explanation: "robots.txt tells search crawlers which pages they can or cannot access on your site."
    },
    {
      q: "What is GEO (Generative Engine Optimization)?",
      options: ["Optimizing for AI-powered search engines", "Creating geographic content", "Auto-generating content", "Location optimization"],
      correct: "a",
      explanation: "GEO optimizes content so AI systems like ChatGPT and Google's SGE can understand and cite it."
    },
    {
      q: "What is the difference between dofollow and nofollow links?",
      options: ["Dofollow passes SEO value, nofollow doesn't", "Nofollow is better", "No difference", "Dofollow is from social media"],
      correct: "a",
      explanation: "Dofollow links pass link equity (SEO value), while nofollow tells search engines not to count the link."
    },
    {
      q: "How many H1 tags should a page have?",
      options: ["One", "Two or three", "As many as you want", "Zero"],
      correct: "a",
      explanation: "Each page should have exactly one H1 tag describing the main topic."
    },
    {
      q: "What does a 404 status code mean?",
      options: ["Page not found", "Server error", "Page moved", "Success"],
      correct: "a",
      explanation: "404 means the page doesn't exist. Fix 404s for good UX and SEO."
    },
    {
      q: "What is Schema markup?",
      options: ["Structured data helping search engines understand content", "Color scheme", "Database structure", "Programming language"],
      correct: "a",
      explanation: "Schema markup is structured data that helps search engines understand content better."
    },
    {
      q: "What is the meta description?",
      options: ["Brief summary for search results", "Main heading", "Keyword list", "Page title"],
      correct: "a",
      explanation: "The meta description is a 150-160 character summary that appears in search results."
    },
    {
      q: "What is LCP in Core Web Vitals?",
      options: ["Largest Contentful Paint - loading time", "Link Click Performance", "Last Content Published", "Local Cache Priority"],
      correct: "a",
      explanation: "LCP measures how long the largest content element takes to load."
    },
    {
      q: "What is E-E-A-T?",
      options: ["Experience, Expertise, Authoritativeness, Trustworthiness", "Engine, Engagement, Analytics", "Every Employee Acts Together", "Electronic Exchange Art"],
      correct: "a",
      explanation: "E-E-A-T is Google's framework for evaluating content quality."
    },
    {
      q: "What is anchor text?",
      options: ["Clickable text in a hyperlink", "Title tag text", "Meta description", "Alt text"],
      correct: "a",
      explanation: "Anchor text is the visible, clickable text in a hyperlink."
    },
    {
      q: "What is Google Business Profile for?",
      options: ["Local SEO and Google Maps", "International SEO", "Image optimization", "Video ranking"],
      correct: "a",
      explanation: "Google Business Profile is essential for local SEO - appearing in local pack and Maps results."
    },
    {
      q: "What is an XML sitemap?",
      options: ["File listing important pages for search engines", "Visual site map", "User database", "Backup file"],
      correct: "a",
      explanation: "An XML sitemap lists your important pages, helping search engines discover and crawl content."
    },
    {
      q: "What is keyword stuffing?",
      options: ["Overusing keywords unnaturally", "Researching keywords", "Natural keyword usage", "Meta keywords tag"],
      correct: "a",
      explanation: "Keyword stuffing is overusing keywords to manipulate rankings - it can hurt your SEO."
    }
  ];

  // Shuffle array function
  function shuffleArray<T>(array: T[]): T[] {
    const shuffled = [...array];
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
  }

  // Get 5 random questions
  function getRandomQuestions(): typeof allQuestions {
    return shuffleArray(allQuestions).slice(0, 5);
  }

  // Render quiz
  function renderQuiz(): void {
    const questions = getRandomQuestions();
    const form = document.getElementById('quickQuizForm') as HTMLFormElement;

    form.innerHTML = questions.map((q, index) => `
      <div class="question-card" data-index="${index}">
        <span class="question-number">Question ${index + 1}</span>
        <p class="question-text">${q.q}</p>
        <div class="options">
          ${q.options.map((opt: string, optIndex: number) => {
            const letter = String.fromCharCode(97 + optIndex);
            return `
              <label class="option-label">
                <input type="radio" name="q${index}" value="${letter}" data-correct="${q.correct}">
                <span class="option-letter">${letter.toUpperCase()})</span>
                <span class="option-text">${opt}</span>
              </label>
            `;
          }).join('')}
        </div>
        <p class="explanation" data-for="q${index}">
          <span class="explanation-icon">💡</span>
          <span class="explanation-text">${q.explanation}</span>
        </p>
      </div>
    `).join('');

    // Store questions for scoring
    (form as any).dataset.questions = JSON.stringify(questions);
  }

  // Initialize quiz
  renderQuiz();

  // New quiz button
  const newQuizBtn = document.getElementById('newQuizBtn');
  const retakeBtn = document.getElementById('retakeBtn');

  const refreshQuiz = () => {
    renderQuiz();
    (document.getElementById('quizResult') as HTMLElement).style.display = 'none';
    (document.getElementById('quickQuizForm') as HTMLElement).style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  newQuizBtn?.addEventListener('click', refreshQuiz);
  retakeBtn?.addEventListener('click', refreshQuiz);

  // Form submit
  const form = document.getElementById('quickQuizForm') as HTMLFormElement;
  form.addEventListener('submit', (e: Event) => {
    e.preventDefault();

    const formData = new FormData(form);
    const questions = JSON.parse((form as any).dataset.questions);
    let correct = 0;

    questions.forEach((q: any, index: number) => {
      const selected = formData.get(`q${index}`);
      const card = form.querySelector(`[data-index="${index}"]`) as HTMLElement;
      const inputs = card.querySelectorAll('input[type="radio"]');
      const explanation = card.querySelector('.explanation') as HTMLElement;

      // Reset and show correct/incorrect
      Array.from(card.querySelectorAll('.option-label')).forEach((label: Element) => {
        (label as HTMLElement).classList.remove('correct', 'incorrect');
      });

      Array.from(inputs).forEach((input: Element) => {
        const inputEl = input as HTMLInputElement;
        const label = inputEl.closest('.option-label') as HTMLElement;
        if (inputEl.dataset.correct === inputEl.value) {
          label.classList.add('correct');
        } else if (inputEl.value === selected) {
          label.classList.add('incorrect');
        }
      });

      // Show explanation
      if (explanation) {
        explanation.classList.add('show');
      }

      if (selected === q.correct) {
        correct++;
      }
    });

    // Show results
    form.style.display = 'none';
    const resultDiv = document.getElementById('quizResult') as HTMLElement;
    resultDiv.style.display = 'block';

    const scoreDiv = resultDiv.querySelector('.result-score') as HTMLElement;
    const messageDiv = resultDiv.querySelector('.result-message') as HTMLElement;
    const percentage = (correct / 5) * 100;

    let scoreClass = 'needs-work';
    let message = '';

    if (percentage === 100) {
      scoreClass = 'perfect';
      message = '🎉 Perfect! You\'re an SEO expert!';
    } else if (percentage >= 80) {
      scoreClass = 'good';
      message = '👏 Great job! Strong SEO knowledge!';
    } else if (percentage >= 60) {
      scoreClass = 'good';
      message = '👍 Good effort! Keep learning.';
    } else {
      message = '📚 Keep studying! Review the levels and try again.';
    }

    scoreDiv.textContent = `${correct}/5`;
    scoreDiv.className = `result-score ${scoreClass}`;
    messageDiv.textContent = message;

    // Save progress to localStorage
    saveQuizProgress('quick-quiz', percentage);

    resultDiv.scrollIntoView({ behavior: 'smooth' });
  });

  // Save quiz progress to localStorage
  function saveQuizProgress(quizId: string, score: number) {
    const storageKey = 'seoCourseProgress';
    const stored = localStorage.getItem(storageKey);
    const progress = stored ? JSON.parse(stored) : {
      levels: { level1: { completed: false, progress: 0 }, level2: { completed: false, progress: 0 }, level3: { completed: false, progress: 0 }, level4: { completed: false, progress: 0 } },
      quizzes: { quickQuiz: { taken: 0, bestScore: 0 }, timedChallenge: { taken: 0, bestScore: 0 }, practiceMode: { taken: 0, bestScore: 0 }, finalTest: { taken: 0, bestScore: 0 } },
      achievements: []
    };

    progress.quizzes.quickQuiz.taken++;
    if (score > progress.quizzes.quickQuiz.bestScore) {
      progress.quizzes.quickQuiz.bestScore = score;
    }

    localStorage.setItem(storageKey, JSON.stringify(progress));
  }
</script>
