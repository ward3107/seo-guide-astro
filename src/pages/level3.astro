---
import Layout from '../layouts/Layout.astro';
import SidebarTOC from '../components/SidebarTOC.astro';

const base = import.meta.env.BASE_URL;

const sections = [
  { id: 'intro', title: 'SEO vs. GEO: The Big Shift', icon: '🚀' },
  { id: 'facts', title: 'Pillar 1: Facts Over Fluff', icon: '📊' },
  { id: 'schema', title: 'Pillar 2: Schema for Trust', icon: '📐' },
  { id: 'structure', title: 'Pillar 3: AI-Ready Structure', icon: '📝' },
  { id: 'entities', title: 'Entity Optimization', icon: '🎯' },
  { id: 'eeat', title: 'E-E-A-T: The Trust Framework', icon: '🛡️' },
  { id: 'audit', title: 'GEO Audit Checklist', icon: '✅' },
  { id: 'quiz', title: 'Final GEO Knowledge Test', icon: '🎯' }
];
---

<Layout title="Level 3: Advanced GEO | Waseem's SEO Guide">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={`${base}/`}>Home</a></li>
      <li><a href={`${base}/level1`}>Level 1</a></li>
      <li><a href={`${base}/level2`}>Level 2</a></li>
      <li aria-current="page">Level 3: Advanced GEO</li>
    </ol>
  </nav>

  <header>
    <span class="badge">LEVEL 3</span>
    <h1>🤖 Advanced GEO Mastery</h1>
    <p class="subtitle">Generative Engine Optimization: Making AI Trust & Quote You</p>
    <div class="reading-time-badge">⏱️ ~50 min read</div>
    <div class="meta">
      <strong>Created for:</strong> Waseem (English Teacher & Coder)<br />
      <strong>Level:</strong> Advanced (After completing Level 1 & 2)<br />
      <strong>Date:</strong> February 2026<br />
      <strong>Topics:</strong> AI Search, Entities, E-E-A-T, Schema for GEO, Q&A Structure, GEO Auditing
    </div>
  </header>

  <!-- Table of Contents -->
  <SidebarTOC sections={sections} />

  <!-- SEO vs GEO -->
  <section id="intro">
    <h2>🚀 SEO vs. GEO: The Big Shift</h2>

    <div class="highlight-box">
      <h4>📚 Remember the Library Analogy?</h4>
      <p><strong>SEO</strong> = Getting your book on the shelf (list of links).</p>
      <p><strong>GEO</strong> = Getting the librarian to <em>read your book out loud</em> (AI answer).</p>
    </div>

    <h3>The Fundamental Difference</h3>
    <table>
      <thead>
        <tr>
          <th>Feature</th>
          <th>SEO (Traditional)</th>
          <th>GEO (AI Search)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Goal</strong></td>
          <td>Rank #1 in links</td>
          <td>Be quoted in the answer</td>
        </tr>
        <tr>
          <td><strong>User Sees</strong></td>
          <td>10 blue links</td>
          <td>A paragraph written by AI</td>
        </tr>
        <tr>
          <td><strong>Success</strong></td>
          <td>User clicks link</td>
          <td>AI cites your website</td>
        </tr>
        <tr>
          <td><strong>Analogy</strong></td>
          <td>Being on the menu</td>
          <td>Being the chef's recommendation</td>
        </tr>
      </tbody>
    </table>

    <div class="success-box">
      <h4>💡 Why Coders Win at GEO</h4>
      <p>AI understands <em>code</em> better than marketing text. Your ability to add Schema and structure gives you a huge advantage!</p>
    </div>
  </section>

  <!-- Facts Over Fluff -->
  <section id="facts">
    <h2>📊 Pillar 1: Facts Over Fluff</h2>

    <h3>What AI Loves vs. What AI Ignores</h3>
    <p>AI models are trained to find <strong>authoritative information</strong>. They hate vague marketing slogans.</p>

    <table>
      <thead>
        <tr>
          <th>❌ Fluff (AI Ignores)</th>
          <th>✅ Facts (AI Quotes)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>"We are the best!"</td>
          <td>"10 years experience, 500+ students"</td>
        </tr>
        <tr>
          <td>"Our lessons are amazing!"</td>
          <td>"95% pass rate on IELTS exams"</td>
        </tr>
        <tr>
          <td>"Contact us for more info!"</td>
          <td>"3-step method proven over 5 years"</td>
        </tr>
      </tbody>
    </table>

    <div class="question-box">
      <h4>🤔 Socratic Question 1</h4>
      <p>You ask AI: <em>"What is the best way to learn English?"</em></p>
      <p><strong>Website A:</strong> "We are the best English school! Click here to learn more!"</p>
      <p><strong>Website B:</strong> "Research shows 30 minutes of daily practice improves fluency by 40%. Waseem's School uses a 3-step coding-based method proven over 10 years."</p>
      <p><strong>Which website is the AI more likely to read and share?</strong></p>
      <div class="tip-box">
        <h4>✅ Answer</h4>
        <p><strong>Website B</strong></p>
        <p>AI loves data, facts, and specific methods. It hates marketing slogans.</p>
      </div>
    </div>
  </section>

  <!-- Schema for Trust -->
  <section id="schema">
    <h2>📐 Pillar 2: Schema for Trust</h2>

    <h3>Why Schema Wins</h3>
    <p>Anyone can write text. Only the site owner can add structured code.</p>

    <h3>Text vs. Schema</h3>
    <pre><code>&lt;!-- ❌ Text (Easy to lie) --&gt;
&lt;p&gt;I am an expert with 10 years experience.&lt;/p&gt;

&lt;!-- ✅ Schema (Structured fact) --&gt;
&lt;script type="application/ld+json"&gt;
&#123;
  "@type": "Person",
  "name": "Waseem",
  "jobTitle": "English Teacher & Coder",
  "yearsOfExperience": 10
&#125;
&lt;/script&gt;</code></pre>

    <div class="question-box">
      <h4>🤔 Socratic Question 2</h4>
      <p>You want to prove <strong>Expertise</strong> on your website.</p>
      <p><strong>Option A:</strong> Write "I am an expert" in big bold text.</p>
      <p><strong>Option B:</strong> Add a Schema snippet with your credentials.</p>
      <p><strong>Which one will the AI trust more?</strong></p>
      <div class="tip-box">
        <h4>✅ Answer</h4>
        <p><strong>Option B (Schema)</strong></p>
        <p>Structured data is harder to fake and easier for AI to parse.</p>
      </div>
    </div>
  </section>

  <!-- AI-Ready Structure -->
  <section id="structure">
    <h2>📝 Pillar 3: AI-Ready Structure</h2>

    <h3>Q&A Format</h3>
    <p>AI models love <strong>patterns</strong>. They scan pages looking for questions and answers.</p>

    <h3>Bad vs. Good Structure</h3>
    <table>
      <thead>
        <tr>
          <th>❌ Hard for AI</th>
          <th>✅ Easy for AI</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Long paragraph (500 words)</td>
          <td>Clear Q&A Section</td>
        </tr>
        <tr>
          <td>No headings</td>
          <td><code>&lt;h2&gt;</code>Question<code>&lt;/h2&gt;</code> + <code>&lt;p&gt;</code>Answer<code>&lt;/p&gt;</code></td>
        </tr>
        <tr>
          <td>Mixed topics</td>
          <td>One topic per section</td>
        </tr>
      </tbody>
    </table>

    <div class="tip-box">
      <h4>💡 Pro Tip</h4>
      <p>Use <strong>FAQ Schema</strong> to mark up your Q&A sections. This tells AI explicitly: "This is a question, and this is the answer."</p>
    </div>

    <div class="question-box">
      <h4>🤔 Socratic Question 3</h4>
      <p>You want AI to quote your advice about "Learning English".</p>
      <p><strong>Option A:</strong> A long paragraph explaining your philosophy.</p>
      <p><strong>Option B:</strong> A clear Q&A Section: <code>&lt;h2&gt;How long does it take?&lt;/h2&gt;&lt;p&gt;3 months with daily practice.&lt;/p&gt;</code></p>
      <p><strong>Which one is easier for AI to extract?</strong></p>
      <div class="tip-box">
        <h4>✅ Answer</h4>
        <p><strong>Option B</strong></p>
        <p>Think about Google's "People Also Ask" boxes. They love clear Q&A!</p>
      </div>
    </div>
  </section>

  <!-- Entity Optimization -->
  <section id="entities">
    <h2>🎯 Entity Optimization</h2>

    <h3>What is an Entity?</h3>
    <p>In the world of AI and search engines, an <strong>entity</strong> is a distinct, well-defined "thing" that can be uniquely identified. Unlike keywords (which are just strings of text), entities have:</p>
    <ul>
      <li><strong>Name:</strong> "Waseem" (not just "teacher")</li>
      <li><strong>Type:</strong> Person, Organization, Place, Concept</li>
      <li><strong>Properties:</strong> Job title, location, expertise</li>
      <li><strong>Relationships:</strong> Connected to other entities</li>
    </ul>

    <div class="highlight-box">
      <h4>🔗 Think of entities like a knowledge graph</h4>
      <p>Google's Knowledge Graph connects "Waseem" → "English Teacher" → "Haifa" → "Coding"</p>
      <p>This context helps AI <strong>understand</strong> your content, not just match keywords.</p>
    </div>

    <h3>Entity Optimization for GEO</h3>
    <p>When AI models generate answers, they prioritize content with <strong>clear entities</strong>. Here's how to optimize:</p>

    <table>
      <thead>
        <tr>
          <th>Entity Element</th>
          <th>How to Optimize</th>
          <th>Why AI Loves It</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Person Entity</strong></td>
          <td>Use Person Schema with name, jobTitle, sameAs</td>
          <td>Proves you're real and verifiable</td>
        </tr>
        <tr>
          <td><strong>Organization Entity</strong></td>
          <td>Use Organization Schema with logo, address</td>
          <td>Establishes institutional authority</td>
        </tr>
        <tr>
          <td><strong>SameAs Links</strong></td>
          <td>Link to LinkedIn, GitHub, Twitter profiles</td>
          <td>Confirms identity across platforms</td>
        </tr>
        <tr>
          <td><strong>Knows About</strong></td>
          <td>Schema mentions your expertise areas</td>
          <td>Helps AI match your content to queries</td>
        </tr>
      </tbody>
    </table>

    <h3>Example: Person Entity Schema</h3>
    <pre><code>&lt;script type="application/ld+json"&gt;
&#123;
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Waseem",
  "jobTitle": "English Teacher & Full-Stack Developer",
  "url": "https://ward3107.github.io",
  "sameAs": [
    "https://github.com/ward3107",
    "https://linkedin.com/in/waseem",
    "https://twitter.com/waseem"
  ],
  "knowsAbout": [
    "English Teaching",
    "Web Development",
    "SEO and GEO",
    "Technical Writing"
  ],
  "worksFor": &#123;
    "@type": "Organization",
    "name": "Freelance"
  &#125;,
  "address": &#123;
    "@type": "PostalAddress",
    "addressLocality": "Haifa",
    "addressCountry": "Israel"
  &#125;
&#125;
&lt;/script&gt;</code></pre>

    <div class="key-takeaway-box">
      <h4>🎯 Key Takeaway</h4>
      <p>Entities are the building blocks of AI understanding. When you define entities clearly with Schema markup, you're giving AI a "map" of your content. The better your entities, the more likely AI will quote you accurately.</p>
    </div>
  </section>

  <!-- E-E-A-T Framework -->
  <section id="eeat">
    <h2>🛡️ E-E-A-T: The Trust Framework</h2>

    <p>Google and AI use <strong>E-E-A-T</strong> to decide if they should trust you:</p>

    <table>
      <thead>
        <tr>
          <th>Letter</th>
          <th>Meaning</th>
          <th>How to Show It in Code</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>E</strong></td>
          <td><strong>Experience</strong></td>
          <td>Case studies, project logs, before/after data</td>
        </tr>
        <tr>
          <td><strong>E</strong></td>
          <td><strong>Expertise</strong></td>
          <td>Author Schema, credentials, qualifications</td>
        </tr>
        <tr>
          <td><strong>A</strong></td>
          <td><strong>Authoritativeness</strong></td>
          <td>Backlinks, citations, mentions by others</td>
        </tr>
        <tr>
          <td><strong>T</strong></td>
          <td><strong>Trustworthiness</strong></td>
          <td>HTTPS, clear contact info, accurate Schema</td>
        </tr>
      </tbody>
    </table>

    <div class="question-box">
      <h4>🤔 Socratic Question 4</h4>
      <p>You write an article: <em>"Coding Helps Learn English Faster."</em></p>
      <p><strong>To make AI trust this claim, what should you add?</strong></p>
      <ol>
        <li>Nothing (Just your opinion).</li>
        <li>A link to a university study + Your Author Schema.</li>
        <li>More exclamation marks!!!</li>
      </ol>
      <div class="tip-box">
        <h4>✅ Answer</h4>
        <p><strong>#2 (Link + Schema)</strong></p>
        <p>This proves you aren't just making it up. AI loves citations!</p>
      </div>
    </div>
  </section>

  <!-- GEO Audit Checklist -->
  <section id="audit">
    <h2>✅ GEO Audit Checklist</h2>

    <p>Before publishing content for AI optimization, run through this checklist. Each item represents a signal that AI looks for when deciding whether to trust and quote your content.</p>

    <div class="geo-checklist">
      <h3>🔍 Your GEO Validation Checklist</h3>

      <div class="checklist-item">
        <label>
          <input type="checkbox" id="check1" onchange="updateChecklist()" />
          <strong>1. Is Schema valid and complete?</strong>
        </label>
        <p>Test your Schema using <a href="https://validator.schema.org" target="_blank" rel="noopener noreferrer">Schema Validator</a> or <a href="https://search.google.com/test/rich-results" target="_blank" rel="noopener noreferrer">Google Rich Results Test</a>. Ensure no errors, and all required fields are populated.</p>
      </div>

      <div class="checklist-item">
        <label>
          <input type="checkbox" id="check2" onchange="updateChecklist()" />
          <strong>2. Is content entity-rich?</strong>
        </label>
        <p>Scan your page for clear entities: person names, organization names, locations, dates. These help AI build context. Vague references reduce your chances of being quoted.</p>
      </div>

      <div class="checklist-item">
        <label>
          <input type="checkbox" id="check3" onchange="updateChecklist()" />
          <strong>3. Does heading structure reflect user intent?</strong>
        </label>
        <p>Use H2/H3 headings that match how users ask questions. "How long does it take?" is better than "Timeline Considerations." AI answers questions, not abstractions.</p>
      </div>

      <div class="checklist-item">
        <label>
          <input type="checkbox" id="check4" onchange="updateChecklist()" />
          <strong>4. Is E-E-A-T clearly visible?</strong>
        </label>
        <p>Author byline, credentials, publication date, and references should be prominent. AI scans for trust signals before quoting sources.</p>
      </div>

      <div class="checklist-item">
        <label>
          <input type="checkbox" id="check5" onchange="updateChecklist()" />
          <strong>5. Is page fast and mobile-friendly?</strong>
        </label>
        <p>Run <a href="https://pagespeed.web.dev" target="_blank" rel="noopener noreferrer">PageSpeed Insights</a>. Core Web Vitals matter because AI systems prioritize sources that provide good user experiences.</p>
      </div>

      <div class="checklist-progress" id="checklistProgress">
        ✅ Progress: 0 of 5 items checked
      </div>
    </div>

    <div class="key-takeaway-box">
      <h4>🎯 Key Takeaway</h4>
      <p>GEO auditing is about removing friction. Every checkbox you clear removes one reason for AI to skip your content. The more boxes you check, the more likely AI will find, trust, and quote you.</p>
    </div>
  </section>

  <!-- Quiz Section -->
  <section id="quiz" class="quiz-section">
    <h2>🎯 Final GEO Knowledge Test</h2>
    <p>Test your understanding of AI Optimization!</p>

    <form id="quiz" class="quiz-form">
      <div class="question" data-question="1">
        <p><strong>1. What is the main goal of GEO?</strong></p>
        <label data-letter="A"><input type="radio" name="q1" value="a"> Rank #1 in links</label>
        <label data-letter="B"><input type="radio" name="q1" value="b"> Be quoted in AI answers</label>
        <label data-letter="C"><input type="radio" name="q1" value="c"> Get more ads</label>
      </div>

      <div class="question" data-question="2">
        <p><strong>2. What does AI prefer?</strong></p>
        <label data-letter="A"><input type="radio" name="q2" value="a"> Marketing slogans</label>
        <label data-letter="B"><input type="radio" name="q2" value="b"> Specific facts and data</label>
        <label data-letter="C"><input type="radio" name="q2" value="c"> Long paragraphs</label>
      </div>

      <div class="question" data-question="3">
        <p><strong>3. Which proves expertise better?</strong></p>
        <label data-letter="A"><input type="radio" name="q3" value="a"> Text saying "I'm an expert"</label>
        <label data-letter="B"><input type="radio" name="q3" value="b"> Schema with credentials</label>
        <label data-letter="C"><input type="radio" name="q3" value="c"> Big images</label>
      </div>

      <div class="question" data-question="4">
        <p><strong>4. What structure does AI love?</strong></p>
        <label data-letter="A"><input type="radio" name="q4" value="a"> Q&A Format</label>
        <label data-letter="B"><input type="radio" name="q4" value="b"> Random text</label>
        <label data-letter="C"><input type="radio" name="q4" value="c"> Hidden text</label>
      </div>

      <div class="question" data-question="5">
        <p><strong>5. What does E-E-A-T stand for?</strong></p>
        <label data-letter="A"><input type="radio" name="q5" value="a"> Easy, Early, All, Time</label>
        <label data-letter="B"><input type="radio" name="q5" value="b"> Experience, Expertise, Authoritativeness, Trust</label>
        <label data-letter="C"><input type="radio" name="q5" value="c"> Email, Engine, Auto, Tech</label>
      </div>

      <div class="question" data-question="6">
        <p><strong>6. How do you help AI verify facts?</strong></p>
        <label data-letter="A"><input type="radio" name="q6" value="a"> Link to external studies</label>
        <label data-letter="B"><input type="radio" name="q6" value="b"> Use bold text</label>
        <label data-letter="C"><input type="radio" name="q6" value="c"> Add more pages</label>
      </div>

      <div class="question" data-question="7">
        <p><strong>7. What schema type is best for authors?</strong></p>
        <label data-letter="A"><input type="radio" name="q7" value="a"> Product</label>
        <label data-letter="B"><input type="radio" name="q7" value="b"> Person</label>
        <label data-letter="C"><input type="radio" name="q7" value="c"> Event</label>
      </div>

      <div class="question" data-question="8">
        <p><strong>8. Why does AI trust Schema?</strong></p>
        <label data-letter="A"><input type="radio" name="q8" value="a"> It's colorful</label>
        <label data-letter="B"><input type="radio" name="q8" value="b"> It's structured and hard to fake</label>
        <label data-letter="C"><input type="radio" name="q8" value="c"> It loads faster</label>
      </div>

      <div class="question" data-question="9">
        <p><strong>9. What is an "entity" in GEO?</strong></p>
        <label data-letter="A"><input type="radio" name="q9" value="a"> A keyword</label>
        <label data-letter="B"><input type="radio" name="q9" value="b"> A distinct thing AI can recognize</label>
        <label data-letter="C"><input type="radio" name="q9" value="c"> A website link</label>
      </div>

      <div class="question" data-question="10">
        <p><strong>10. Who has the advantage in GEO?</strong></p>
        <label data-letter="A"><input type="radio" name="q10" value="a"> Marketers</label>
        <label data-letter="B"><input type="radio" name="q10" value="b"> Coders who know Schema</label>
        <label data-letter="C"><input type="radio" name="q10" value="c"> Graphic designers</label>
      </div>

      <div class="question" data-question="11">
        <p><strong>11. What property connects your profiles across platforms?</strong></p>
        <label data-letter="A"><input type="radio" name="q11" value="a"> sameAs</label>
        <label data-letter="B"><input type="radio" name="q11" value="b"> url</label>
        <label data-letter="C"><input type="radio" name="q11" value="c"> name</label>
      </div>

      <div class="question" data-question="12">
        <p><strong>12. Which Core Web Vital measures visual stability?</strong></p>
        <label data-letter="A"><input type="radio" name="q12" value="a"> LCP</label>
        <label data-letter="B"><input type="radio" name="q12" value="b"> FID</label>
        <label data-letter="C"><input type="radio" name="q12" value="c"> CLS</label>
      </div>

      <button type="submit" class="quiz-submit">Submit Quiz</button>
      <div id="quizResult" class="quiz-result"></div>
    </form>
  </section>

  <!-- Navigation Footer -->
  <nav class="level-nav">
    <a href={`${base}/level2`} class="nav-btn">← Level 2: Technical SEO</a>
    <a href={`${base}/level4`} class="nav-btn">Level 4: Authority Channels →</a>
  </nav>
</Layout>

<style>
  .breadcrumbs {
    margin-bottom: 30px;
  }

  .breadcrumbs ol {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 8px;
    flex-wrap: wrap;
  }

  .breadcrumbs li {
    color: #666;
  }

  .breadcrumbs li:not(:last-child)::after {
    content: '→';
    margin-left: 8px;
    color: #999;
  }

  .breadcrumbs a {
    color: #667eea;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  header {
    text-align: center;
    margin-bottom: 40px;
  }

  .badge {
    display: inline-block;
    background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    color: white;
    padding: 8px 20px;
    border-radius: 25px;
    font-weight: 600;
    margin-bottom: 20px;
  }

  header h1 {
    font-size: 2.5em;
    margin-bottom: 10px;
    color: #333;
  }

  .subtitle {
    font-size: 1.3em;
    color: #764ba2;
    margin-bottom: 20px;
  }

  .reading-time-badge {
    display: inline-block;
    background: #f0f0f0;
    padding: 6px 16px;
    border-radius: 15px;
    font-size: 0.9em;
    color: #666;
  }

  .meta {
    margin-top: 20px;
    color: #666;
    line-height: 1.8;
  }

  .learn-box,
  .reflect-box,
  .practice-box,
  .verify-box,
  .tip-box,
  .highlight-box,
  .warning-box,
  .success-box,
  .key-takeaway-box,
  .question-box {
    padding: 20px;
    border-radius: 12px;
    margin: 20px 0;
  }

  .learn-box {
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
    border-left: 5px solid #2196f3;
  }

  .reflect-box {
    background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
    border-left: 5px solid #ff9800;
  }

  .practice-box {
    background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
    border-left: 5px solid #9c27b0;
