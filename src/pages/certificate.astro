---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

// Get current date for certificate
const currentDate = new Date();
const formattedDate = currentDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout title="Certificate | Waseem's SEO Guide">
  <div id="certificateContent"></div>
</Layout>

<style>
  .certificate-intro {
    background: var(--gradient-card);
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 30px;
    text-align: center;
  }

  .certificate-intro h2 {
    color: var(--color-brand-primary);
    margin-bottom: 15px;
  }

  .certificate-intro p {
    color: var(--color-text-secondary);
    font-size: 1.1em;
    line-height: 1.6;
  }

  .certificate-generator {
    max-width: 1000px;
    margin: 0 auto 40px;
  }

  .input-section {
    background: var(--color-surface);
    border-radius: 15px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: var(--shadow-sm);
  }

  .name-label {
    display: block;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 15px;
    font-size: 1.1em;
  }

  .input-group {
    display: flex;
    gap: 15px;
    margin-bottom: 10px;
  }

  .input-group input {
    flex: 1;
    padding: 15px 20px;
    border: 2px solid var(--color-border);
    border-radius: 10px;
    font-size: 1.1em;
    transition: border-color 0.3s ease;
  }

  .input-group input:focus {
    outline: none;
    border-color: var(--color-brand-primary);
  }

  .generate-btn {
    padding: 15px 30px;
    background: var(--color-brand-gradient);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1.1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .generate-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .input-hint {
    color: var(--color-text-muted);
    font-size: 0.95em;
    font-style: italic;
  }

  .certificate-preview {
    background: #f5f5f5;
    border-radius: 15px;
    padding: 30px;
    margin-bottom: 30px;
    overflow: hidden;
  }

  .certificate-border {
    background: var(--gradient-certificate);
    padding: 15px;
    border-radius: 10px;
    box-shadow: var(--shadow-lg);
  }

  .certificate-inner {
    background: var(--color-surface);
    padding: 50px;
    border-radius: 5px;
    position: relative;
    min-height: 500px;
  }

  .cert-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .cert-logo {
    font-size: 4em;
    margin-bottom: 10px;
  }

  .cert-title {
    font-size: 2.5em;
    background: var(--color-brand-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 10px 0;
    font-family: 'Georgia', serif;
  }

  .cert-subtitle {
    font-size: 1.3em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .cert-body {
    text-align: center;
    margin-bottom: 40px;
  }

  .cert-presentation {
    font-size: 1.2em;
    color: var(--color-text-secondary);
    margin-bottom: 15px;
  }

  .cert-name {
    font-size: 2.8em;
    font-weight: bold;
    color: var(--color-text);
    margin: 20px 0;
    font-family: 'Georgia', serif;
    padding: 15px;
    border-bottom: 3px solid var(--color-certificate-accent);
    display: inline-block;
    min-width: 300px;
  }

  .cert-description {
    font-size: 1.1em;
    color: var(--color-text-muted);
    margin: 20px 0;
    line-height: 1.6;
  }

  .cert-skills {
    list-style: none;
    padding: 0;
    margin: 30px 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
  }

  .cert-skills li {
    background: var(--gradient-card);
    padding: 10px 20px;
    border-radius: 25px;
    color: var(--color-text-secondary);
    font-size: 0.95em;
  }

  .cert-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    position: relative;
    padding-top: 20px;
  }

  .cert-date,
  .cert-instructor {
    flex: 1;
  }

  .cert-date {
    text-align: left;
  }

  .cert-instructor {
    text-align: right;
  }

  .date-label,
  .instructor-label {
    display: block;
    font-size: 0.9em;
    color: var(--color-text-muted);
    margin-bottom: 5px;
  }

  .date-value,
  .instructor-value {
    font-size: 1.1em;
    color: var(--color-text);
    font-weight: 600;
  }

  .cert-seal {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
  }

  .seal-inner {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-brand-gradient);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5em;
    font-weight: bold;
    box-shadow: var(--shadow-md);
  }

  .action-buttons {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 30px;
  }

  .print-btn,
  .download-btn,
  .home-btn {
    padding: 15px 35px;
    border-radius: 50px;
    font-size: 1.1em;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .print-btn {
    background: var(--color-brand-gradient);
    color: white;
    border: none;
  }

  .download-btn {
    background: var(--gradient-success);
    color: white;
    border: none;
  }

  .home-btn {
    background: var(--color-surface-elevated);
    color: var(--color-brand-primary);
    border: 2px solid var(--color-brand-primary);
  }

  .print-btn:hover,
  .download-btn:hover,
  .home-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .certificate-note {
    background: #fff9e6;
    border-left: 4px solid var(--color-warning);
    border-radius: 10px;
    padding: 20px;
    text-align: center;
  }

  .certificate-note p {
    color: #856404;
    margin: 0;
  }

  /* Dark mode */
  :global(body.dark-mode) .certificate-intro,
  :global([data-theme="dark"]) .certificate-intro {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }

  :global(body.dark-mode) .certificate-intro p,
  :global([data-theme="dark"]) .certificate-intro p {
    color: var(--color-text-secondary);
  }

  :global(body.dark-mode) .input-section,
  :global(body.dark-mode) .certificate-preview,
  :global([data-theme="dark"]) .input-section,
  :global([data-theme="dark"]) .certificate-preview {
    background: var(--color-surface-elevated);
  }

  :global(body.dark-mode) .name-label,
  :global([data-theme="dark"]) .name-label {
    color: var(--color-text);
  }

  :global(body.dark-mode) .input-group input,
  :global([data-theme="dark"]) .input-group input {
    background: #2a2a4a;
    border-color: var(--color-border);
    color: var(--color-text);
  }

  :global(body.dark-mode) .input-hint,
  :global([data-theme="dark"]) .input-hint {
    color: var(--color-text-secondary);
  }

  :global(body.dark-mode) .certificate-note,
  :global([data-theme="dark"]) .certificate-note {
    background: #2a2a4a;
  }

  :global(body.dark-mode) .certificate-note p,
  :global([data-theme="dark"]) .certificate-note p {
    color: var(--color-text-secondary);
  }

  /* Certificate Locked Styles */
  .certificate-locked {
    background: linear-gradient(135deg, #fff3cd 0%, #ffe8a1 100%);
    border-radius: 20px;
    padding: 60px 40px;
    text-align: center;
    margin: 40px 0;
    border: 2px solid var(--color-warning);
  }

  .locked-content {
    max-width: 500px;
    margin: 0 auto;
  }

  .lock-icon {
    font-size: 4em;
    display: block;
    margin-bottom: 20px;
  }

  .certificate-locked h2 {
    color: #856404;
    margin-bottom: 15px;
  }

  .certificate-locked p {
    color: #856404;
    font-size: 1.1em;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .level-status {
    background: rgba(255, 255, 255, 0.5);
    border-radius: 15px;
    padding: 20px;
    margin: 20px auto;
  }

  .level-status p {
    font-weight: 600;
    margin-bottom: 10px;
  }

  .level-status ul {
    list-style: none;
    padding: 0;
    text-align: left;
  }

  .back-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 30px;
    background: var(--color-brand-gradient);
    color: white;
    text-decoration: none;
    border-radius: 30px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .back-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  :global(body.dark-mode) .certificate-locked,
  :global([data-theme="dark"]) .certificate-locked {
    background: linear-gradient(135deg, #3a3a2a 0%, #4a4a3a 100%);
    border-color: #6a6a4a;
  }

  :global(body.dark-mode) .certificate-locked h2,
  :global(body.dark-mode) .certificate-locked p,
  :global([data-theme="dark"]) .certificate-locked h2,
  :global([data-theme="dark"]) .certificate-locked p {
    color: #d4c77a;
  }

  :global(body.dark-mode) .level-status,
  :global([data-theme="dark"]) .level-status {
    background: rgba(0, 0, 0, 0.2);
  }

  /* Print styles */
  @media print {
    body * {
      visibility: hidden;
    }

    .certificate-preview,
    .certificate-preview * {
      visibility: visible;
    }

    .certificate-preview {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      margin: 0;
      padding: 0;
      background: white;
    }

    .certificate-border {
      box-shadow: none;
    }

    @page {
      size: landscape;
      margin: 0.5cm;
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .input-group {
      flex-direction: column;
    }

    .cert-footer {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .cert-date,
    .cert-instructor {
      text-align: center;
    }

    .cert-seal {
      position: static;
      transform: none;
      margin: 20px 0;
    }

    .cert-name {
      font-size: 2em;
      min-width: auto;
      width: 100%;
    }

    .cert-title {
      font-size: 1.8em;
    }

    .action-buttons {
      flex-direction: column;
    }

    .print-btn,
    .download-btn,
    .home-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script is:inline>
  (function() {
    const base = '/seo-guide-astro/';
    const storageKey = 'seoCourseProgress';
    const stored = localStorage.getItem(storageKey);
    const progress = stored ? JSON.parse(stored) : {
      levels: {
        level1: { completed: false },
        level2: { completed: false },
        level3: { completed: false },
        level4: { completed: false }
      }
    };

    const allCompleted = progress.levels.level1.completed &&
                        progress.levels.level2.completed &&
                        progress.levels.level3.completed &&
                        progress.levels.level4.completed;

    const container = document.getElementById('certificateContent');

    if (allCompleted) {
      // Show certificate
      const currentDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
      container.innerHTML = `
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <ol>
            <li><a href="${base}/">Home</a></li>
            <li aria-current="page">Certificate</li>
          </ol>
        </nav>
        <header>
          <span class="badge">🎓 CERTIFICATE</span>
          <h1>Certificate of Completion</h1>
          <p class="subtitle">Congratulations on completing Waseem's SEO & GEO Course!</p>
        </header>
        <section class="certificate-intro">
          <h2>🏆 Your Achievement</h2>
          <p>Enter your name below to generate your personalized certificate of completion for the SEO & GEO Mastery Course.</p>
        </section>
        <div class="certificate-generator">
          <div class="input-section">
            <label for="studentName" class="name-label">Enter Your Full Name:</label>
            <div class="input-group">
              <input type="text" id="studentName" name="studentName" placeholder="John Doe" maxlength="50" aria-label="Enter your full name for the certificate" />
              <button class="generate-btn" id="generateBtn">Generate Certificate</button>
            </div>
            <p class="input-hint">Your name will appear on the certificate exactly as you type it.</p>
          </div>
        </div>
        <div class="certificate-preview" id="certificatePreview">
          <div class="certificate-border">
            <div class="certificate-inner">
              <div class="cert-header">
                <div class="cert-logo">🎓</div>
                <h1 class="cert-title">Certificate of Completion</h1>
                <p class="cert-subtitle">SEO & GEO Mastery Course</p>
              </div>
              <div class="cert-body">
                <p class="cert-presentation">This is to proudly certify that</p>
                <p class="cert-name" id="certName">[Your Name]</p>
                <p class="cert-description">has successfully completed the comprehensive SEO & GEO Mastery Course, demonstrating proficiency in:</p>
                <ul class="cert-skills">
                  <li>Search Engine Optimization (SEO) Fundamentals</li>
                  <li>Technical SEO & Performance Optimization</li>
                  <li>Generative Engine Optimization (GEO)</li>
                  <li>Local SEO & Authority Building</li>
                </ul>
              </div>
              <div class="cert-footer">
                <div class="cert-date">
                  <span class="date-label">Date of Completion</span>
                  <span class="date-value" id="certDate">${currentDate}</span>
                </div>
                <div class="cert-instructor">
                  <span class="instructor-label">Course Instructor</span>
                  <span class="instructor-value">Waseem</span>
                </div>
                <div class="cert-seal">
                  <div class="seal-inner">✓</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="action-buttons">
          <button class="print-btn" id="printBtn">🖨️ Print Certificate</button>
          <button class="download-btn" id="downloadBtn">⬇️ Download as Image</button>
          <a href="${base}/" class="home-btn">← Back to Home</a>
        </div>
        <section class="certificate-note">
          <p>💡 <strong>Tip:</strong> For best results when printing, use landscape orientation and high-quality paper.</p>
        </section>
      `;

      // Attach event listeners
      document.getElementById('generateBtn').addEventListener('click', function() {
        const studentNameInput = document.getElementById('studentName');
        const certName = document.getElementById('certName');
        if (!studentNameInput || !certName) return;
        const name = studentNameInput.value.trim();
        if (name) {
          certName.textContent = name;
          certName.style.color = '#667eea';
          certName.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          studentNameInput.style.borderColor = '#dc3545';
          setTimeout(function() { studentNameInput.style.borderColor = '#e0e0e0'; }, 1000);
          studentNameInput.focus();
        }
      });

      document.getElementById('studentName').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') document.getElementById('generateBtn').click();
      });

      document.getElementById('printBtn').addEventListener('click', function() { window.print(); });
      document.getElementById('downloadBtn').addEventListener('click', function() {
        alert("To save as PDF:\n\n1. Click Print\n2. Select \"Save as PDF\" as the destination\n3. Click Save\n\nAlternatively, use your browser's screenshot tool to capture the certificate.");
        window.print();
      });
    } else {
      // Show locked message
      const levels = [
        { name: 'Level 1: SEO Basics', completed: progress.levels.level1.completed },
        { name: 'Level 2: Technical SEO', completed: progress.levels.level2.completed },
        { name: 'Level 3: Advanced GEO', completed: progress.levels.level3.completed },
        { name: 'Level 4: Authority & Channels', completed: progress.levels.level4.completed }
      ];

      let levelListHtml = '';
      for (var i = 0; i < levels.length; i++) {
        var level = levels[i];
        var color = level.completed ? '#28a745' : '#dc3545';
        var icon = level.completed ? '✅' : '❌';
        levelListHtml += '<li style="color: ' + color + '; margin-bottom: 8px;">' + icon + ' ' + level.name + '</li>';
      }

      container.innerHTML = `
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <ol>
            <li><a href="${base}/">Home</a></li>
            <li aria-current="page">Certificate</li>
          </ol>
        </nav>
        <div class="certificate-locked">
          <div class="locked-content">
            <span class="lock-icon">🔒</span>
            <h2>Certificate Locked</h2>
            <p>You need to complete all 4 levels before you can access your certificate.</p>
            <div class="level-status">
              <p>Your progress:</p>
              <ul id="levelProgressList">${levelListHtml}</ul>
            </div>
            <a href="${base}/" class="back-btn">← Back to Course</a>
          </div>
        </div>
      `;
    }
  })();
</script>
