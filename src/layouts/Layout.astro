---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  currentLevel?: number;
}

const {
  title = 'Waseem | English Teacher & Full-Stack SEO Developer',
  description = 'Waseem - English Teacher & Full-Stack Developer specializing in SEO and GEO. Building websites that Google AND AI love. Based in Haifa, Israel.',
  image = '/favicon.svg',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  currentLevel = 0
} = Astro.props;

const base = import.meta.env.BASE_URL;

const levels = [
  { number: 1, title: 'SEO Basics', icon: '📘', href: `${base}/level1`, color: '#667eea' },
  { number: 2, title: 'Technical SEO', icon: '🛠️', href: `${base}/level2`, color: '#764ba2' },
  { number: 3, title: 'Advanced GEO', icon: '🤖', href: `${base}/level3`, color: '#f093fb' },
  { number: 4, title: 'Authority & Channels', icon: '🌐', href: `${base}/level4`, color: '#4facfe' }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32x32.png`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${base}/favicon-16x16.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
  <link rel="manifest" href={`${base}/site.webmanifest`} />

  <!-- Prefetch next pages for faster navigation -->
  <link rel="prefetch" href={`${base}/level1/`} />
  <link rel="prefetch" href={`${base}/level2/`} />
  <link rel="prefetch" href={`${base}/level3/`} />
  <link rel="prefetch" href={`${base}/level4/`} />
  <link rel="prefetch" href={`${base}/quick-quiz/`} />
  <link rel="prefetch" href={`${base}/timed-challenge/`} />
  <link rel="prefetch" href={`${base}/practice-mode/`} />
  <link rel="prefetch" href={`${base}/final-test/`} />

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Plausible Analytics -->
  <script defer data-domain="ward3107.github.io" src="https://plausible.io/js/script.js"></script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Waseem" />

  <!-- Open Graph Meta Tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={new URL(image, Astro.url)} />

  <!-- Twitter Card Meta Tags -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <title>{title}</title>

  <!-- Schema.org Person Markup -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Waseem",
      "jobTitle": "English Teacher & Full-Stack Developer",
      "description": "Full-Stack Developer specializing in SEO and GEO (Generative Engine Optimization)",
      "url": "https://ward3107.github.io",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Haifa",
        "addressCountry": "Israel"
      },
      "sameAs": [
        "https://linkedin.com/in/ward3107",
        "https://github.com/ward3107"
      ],
      "knowsAbout": ["SEO", "GEO", "Web Development", "Technical SEO", "Schema Markup", "HTML", "CSS", "JavaScript"],
      "worksFor": {
        "@type": "Organization",
        "name": "Freelance"
      }
    }
  </script>
</head>

<body>
  <!-- Reading Progress Bar -->
  <div class="reading-progress" id="readingProgress"></div>

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <main class="container" id="main-content" role="main" data-base={base}>
    <!-- Navigation -->
    <nav class="nav-links" aria-label="Level navigation">
      <a href={base} class="nav-btn">🏠 Home</a>
      {levels.map(level => (
        <a href={level.href} class="nav-btn" style={currentLevel === level.number ? 'background: linear-gradient(135deg, ' + level.color + ' 0%, ' + level.color + 'aa 100%);' : ''}>
          {level.icon} Level {level.number}
        </a>
      ))}
    </nav>

    <!-- Main Content -->
    <slot />

    <!-- Footer -->
    <footer>
      <!-- Contact Info -->
      <div class="contact-info">
        <div class="contact-item">
          <span aria-hidden="true">📍</span>
          <address style="display: inline; font-style: normal;">Haifa, Israel</address>
        </div>
        <div class="contact-item">
          <span aria-hidden="true">💼</span>
          <a href="https://github.com/ward3107" target="_blank" rel="noopener noreferrer">Visit GitHub Profile</a>
        </div>
        <div class="contact-item">
          <span aria-hidden="true">🌐</span>
          <a href="https://ward3107.github.io" target="_blank" rel="noopener noreferrer">ward3107.github.io</a>
        </div>
      </div>

      <!-- Social Share Buttons -->
      <div class="social-share">
        <span class="share-label">Share this portfolio:</span>
        <a href="https://wa.me/?text=Check%20out%20this%20amazing%20SEO%20portfolio!%20https://ward3107.github.io" target="_blank" rel="noopener noreferrer" class="share-btn whatsapp">
          💬 WhatsApp
        </a>
        <button class="share-btn share" onclick="shareContent()" id="shareBtn">
          📤 Share
        </button>
      </div>

      <p>&copy; 2026 Waseem. All rights reserved.</p>
      <p style="margin-top: 10px; font-size: 0.85em;">
        English Teacher & Full-Stack Developer | SEO & GEO Specialist
      </p>
    </footer>
  </main>

  <!-- Dark Mode Toggle Button -->
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
    🌙
  </button>

  <!-- Back to Top Button -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    ↑
  </button>

  <!-- Global Styles -->
  <style is:global>
    :root {
      /* Light Mode Colors */
      --color-bg: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      --color-text: #333;
      --color-text-secondary: #555;
      --color-text-muted: #666;
      --color-surface: #ffffff;
      --color-surface-elevated: #f8f9fa;
      --color-border: #e0e0e0;
      --color-border-light: #eee;

      /* Brand Colors - Light Mode */
      --color-brand-primary: #667eea;
      --color-brand-secondary: #764ba2;
      --color-brand-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      --color-brand-hover: linear-gradient(135deg, #4a5699 0%, #5a4a7a 100%);
      --color-brand-shadow: rgba(85, 104, 211, 0.4);

      /* Semantic Colors */
      --color-success: #28a745;
      --color-success-hover: #218838;
      --color-error: #dc3545;
      --color-warning: #ffc107;
      --color-info: #17a2b8;

      /* Interactive Elements */
      --color-link: #5568d3;
      --color-link-hover: #4a5699;
      --color-btn-ghost: #6c757d;

      /* Certificate Accent */
      --color-certificate-accent: #ffd93d;
      --color-certificate-accent-dark: #e6c235;

      /* Opacity */
      --opacity-buttons: 0.5;

      /* Shadows */
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.08);
      --shadow-md: 0 5px 20px rgba(0, 0, 0, 0.1);
      --shadow-lg: 0 10px 30px rgba(0, 0, 0, 0.15);
      --shadow-brand: 0 4px 15px rgba(85, 104, 211, 0.4);

      /* Gradients */
      --gradient-brand: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      --gradient-brand-hover: linear-gradient(135deg, #5568d3 0%, #6a4c9c 100%);
      --gradient-success: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
      --gradient-card: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      --gradient-certificate: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
      --gradient-progress: linear-gradient(90deg, #28a745 0%, #20c997 100%);

      /* Theme Toggle Button Gradient */
      --gradient-theme-toggle: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      --gradient-theme-toggle-dark: linear-gradient(135deg, #f39c12 0%, #e74c3c 100%);

      /* Skip Link */
      --color-skip-link-bg: #4a5699;
      --color-skip-link-text: #ffffff;

      /* WhatsApp Button */
      --color-whatsapp: #128C7E;
      --color-whatsapp-hover: #075E54;

      /* Footer */
      --color-footer-bg: transparent;
      --color-footer-text: inherit;

      /* Reading Progress */
      --color-progress-bar: linear-gradient(90deg, #28a745 0%, #20c997 100%);

      /* Focus States */
      --color-focus-ring: #667eea;
      --color-focus-outline: #667eea;

      /* Highlight */
      --color-search-highlight: #ffeb3b;

      /* Transition */
      --transition-theme: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }

    [data-theme="dark"] {
      /* Dark Mode Colors */
      --color-bg: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      --color-text: #e0e0e0;
      --color-text-secondary: #c0c0c0;
      --color-text-muted: #b0b0b0;
      --color-surface: #1e1e30;
      --color-surface-elevated: #252540;
      --color-border: #3a3a5a;
      --color-border-light: #2a2a4a;

      /* Brand Colors - Dark Mode (adjusted for readability) */
      --color-brand-primary: #8a9aff;
      --color-brand-secondary: #9a7cc2;
      --color-brand-gradient: linear-gradient(135deg, #7a8aee 0%, #8a6ab2 100%);
      --color-brand-hover: linear-gradient(135deg, #6a7adc 0%, #7a5a9c 100%);
      --color-brand-shadow: rgba(138, 154, 255, 0.3);

      /* Interactive Elements - Dark Mode */
      --color-link: #8a9aff;
      --color-link-hover: #aab5ff;

      /* Certificate Accent - Gold in Dark Mode */
      --color-certificate-accent: #ffcc00;
      --color-certificate-accent-dark: #e6b800;

      /* Opacity */
      --opacity-buttons: 0.5;

      /* Shadows - Dark Mode */
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
      --shadow-md: 0 5px 20px rgba(0, 0, 0, 0.4);
      --shadow-lg: 0 10px 30px rgba(0, 0, 0, 0.5);
      --shadow-brand: 0 4px 15px rgba(138, 154, 255, 0.3);

      /* Gradients - Dark Mode */
      --gradient-brand: linear-gradient(135deg, #3a3a5a 0%, #4a4a6a 100%);
      --gradient-brand-hover: linear-gradient(135deg, #4a4a6a 0%, #5a5a7a 100%);
      --gradient-card: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      --gradient-certificate: linear-gradient(135deg, #7a8aee 0%, #8a6ab2 50%, #c0a0d0 100%);

      /* Skip Link - Dark Mode */
      --color-skip-link-bg: #4a5699;
      --color-skip-link-text: #ffffff;

      /* Heading Colors - Dark Mode */
      --color-heading-primary: #a8dadc;
      --color-heading-secondary: #a8dadc;
      --color-heading-tertiary: #a8dadc;
    }

    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) {
        --color-bg: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        --color-text: #e0e0e0;
        --color-text-secondary: #c0c0c0;
        --color-text-muted: #b0b0b0;
        --color-surface: #1e1e30;
        --color-surface-elevated: #252540;
        --color-border: #3a3a5a;
        --color-border-light: #2a2a4a;

        --color-brand-primary: #8a9aff;
        --color-brand-secondary: #9a7cc2;
        --color-brand-gradient: linear-gradient(135deg, #7a8aee 0%, #8a6ab2 100%);
        --color-brand-hover: linear-gradient(135deg, #6a7adc 0%, #7a5a9c 100%);
        --color-brand-shadow: rgba(138, 154, 255, 0.3);

        --color-link: #8a9aff;
        --color-link-hover: #aab5ff;

        --color-certificate-accent: #ffcc00;
        --color-certificate-accent-dark: #e6b800;

        --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
        --shadow-md: 0 5px 20px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 10px 30px rgba(0, 0, 0, 0.5);
        --shadow-brand: 0 4px 15px rgba(138, 154, 255, 0.3);

        --gradient-brand: linear-gradient(135deg, #3a3a5a 0%, #4a4a6a 100%);
        --gradient-brand-hover: linear-gradient(135deg, #4a4a6a 0%, #5a5a7a 100%);
        --gradient-card: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        --gradient-certificate: linear-gradient(135deg, #7a8aee 0%, #8a6ab2 50%, #c0a0d0 100%);

        --color-heading-primary: #a8dadc;
        --color-heading-secondary: #a8dadc;
        --color-heading-tertiary: #a8dadc;
      }
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      line-height: 1.6;
      color: var(--color-text);
      background: var(--color-bg);
      min-height: 100vh;
      padding: 20px;
      transition: var(--transition-theme);
    }

    /* Skip Link for Accessibility */
    .skip-link {
      position: absolute;
      top: -40px;
      left: 0;
      background: var(--color-skip-link-bg);
      color: var(--color-skip-link-text);
      padding: 8px 16px;
      text-decoration: none;
      border-radius: 0 0 4px 0;
      z-index: 100;
      font-weight: 600;
    }

    .skip-link:focus {
      top: 0;
    }

    /* Dark Mode - Legacy class support (gradually migrating to data-theme) */
    body.dark-mode {
      background: var(--color-bg);
    }

    body.dark-mode .container {
      background: var(--color-surface);
      color: var(--color-text);
    }

    body.dark-mode .nav-links .nav-btn {
      background: var(--gradient-brand);
      color: var(--color-text);
    }

    body.dark-mode .nav-links .nav-btn:hover {
      background: var(--gradient-brand-hover);
    }

    body.dark-mode h1,
    body.dark-mode h2,
    body.dark-mode h3 {
      color: var(--color-heading-primary, #a8dadc);
    }

    body.dark-mode p,
    body.dark-mode li {
      color: var(--color-text-secondary);
    }

    body.dark-mode footer {
      background: var(--color-footer-bg);
    }

    body.dark-mode footer p {
      color: var(--color-footer-text);
    }

    body.dark-mode .contact-item {
      color: var(--color-text-secondary);
    }

    body.dark-mode .share-label {
      color: var(--color-text-muted);
    }

    /* Container */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      background: var(--color-surface);
      border-radius: 20px;
      box-shadow: var(--shadow-lg);
      padding: 40px;
      margin-bottom: 20px;
      transition: var(--transition-theme);
    }

    /* Navigation */
    .nav-links {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
      margin: 30px 0;
    }

    .nav-btn {
      padding: 12px 24px;
      background: var(--gradient-brand-hover);
      color: var(--color-text);
      text-decoration: none;
      border-radius: 12px;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: var(--shadow-brand);
    }

    .nav-btn:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-brand), 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    /* Dark Mode Toggle */
    .theme-toggle {
      position: fixed;
      bottom: 100px;
      right: 30px;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: var(--gradient-theme-toggle);
      color: white;
      border: none;
      cursor: pointer;
      box-shadow: var(--shadow-md);
      font-size: 1.5em;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      transition: all 0.3s ease;
      opacity: var(--opacity-buttons);
    }

    .theme-toggle:hover {
      transform: scale(1.1);
      opacity: 1;
    }

    body.dark-mode .theme-toggle,
    [data-theme="dark"] .theme-toggle {
      background: var(--gradient-theme-toggle-dark);
    }

    /* Back to Top Button */
    .back-to-top {
      position: fixed;
      bottom: 30px;
      right: 30px;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: var(--gradient-theme-toggle);
      color: white;
      border: none;
      cursor: pointer;
      box-shadow: var(--shadow-md);
      font-size: 1.5em;
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 999;
      transition: all 0.3s ease;
      opacity: var(--opacity-buttons);
    }

    .back-to-top.show {
      display: flex;
    }

    .back-to-top:hover {
      opacity: 1;
    }

    body.dark-mode .back-to-top,
    [data-theme="dark"] .back-to-top {
      background: var(--gradient-theme-toggle-dark);
    }

    /* Reading Progress Bar */
    .reading-progress {
      position: fixed;
      top: 0;
      left: 0;
      width: 0%;
      height: 4px;
      background: var(--gradient-progress);
      z-index: 9999;
      transition: width 0.1s ease;
    }

    /* Footer */
    footer {
      margin-top: 60px;
      padding-top: 40px;
      border-top: 2px solid var(--color-border-light);
    }

    .contact-info {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
      margin-bottom: 30px;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--color-text-secondary);
      font-weight: 500;
    }

    .contact-item a {
      color: var(--color-link);
      text-decoration: none;
      font-weight: 600;
    }

    .social-share {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin-bottom: 20px;
      flex-wrap: wrap;
      align-items: center;
    }

    .share-label {
      color: var(--color-text-secondary);
      font-size: 0.9em;
      font-weight: 500;
    }

    .share-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 18px;
      border-radius: 25px;
      text-decoration: none;
      font-size: 0.9em;
      cursor: pointer;
      border: none;
      transition: all 0.3s ease;
      font-weight: 600;
    }

    .share-btn.whatsapp {
      background: var(--color-whatsapp);
      color: white;
    }

    .share-btn.share {
      background: var(--color-btn-ghost);
      color: white;
    }

    .share-btn:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-sm);
    }

    /* Responsive */
    @media (max-width: 768px) {
      .container {
        padding: 20px;
      }

      .nav-links {
        flex-direction: column;
      }

      .nav-btn {
        width: 100%;
        text-align: center;
      }
    }

    /* Search Highlight */
    .search-highlight {
      background: var(--color-search-highlight);
      padding: 2px 4px;
      border-radius: 3px;
    }

    /* Sidebar TOC - Push Layout (only when sidebar exists) */
    @media (min-width: 1025px) {
      body:has(.sidebar-toc) {
        transition: margin-left 0.3s ease-in-out;
      }

      /* When sidebar is open on desktop */
      body:has(.sidebar-toc).sidebar-open {
        margin-left: 280px;
      }

      /* When sidebar is closed on desktop */
      body:has(.sidebar-toc).sidebar-closed {
        margin-left: 0;
      }
    }
  </style>

  <!-- Inline Scripts for Core Functionality -->
  <script is:inline>
    // Dark Mode Toggle - Using data-theme attribute for CSS variables
    const themeToggle = document.getElementById('themeToggle');
    const currentTheme = localStorage.getItem('theme') || 'light';

    // Apply theme on load
    if (currentTheme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
      document.body.classList.add('dark-mode'); // Keep for backward compatibility
      if (themeToggle) themeToggle.textContent = '☀️';
    } else {
      document.documentElement.setAttribute('data-theme', 'light');
      document.body.classList.remove('dark-mode'); // Keep for backward compatibility
    }

    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const currentAttr = document.documentElement.getAttribute('data-theme');
        const newTheme = currentAttr === 'dark' ? 'light' : 'dark';

        // Update both data-theme (for CSS variables) and class (for backward compatibility)
        document.documentElement.setAttribute('data-theme', newTheme);
        if (newTheme === 'dark') {
          document.body.classList.add('dark-mode');
          themeToggle.textContent = '☀️';
        } else {
          document.body.classList.remove('dark-mode');
          themeToggle.textContent = '🌙';
        }

        localStorage.setItem('theme', newTheme);
      });
    }

    // Back to Top Button
    const backToTop = document.getElementById('backToTop');

    if (backToTop) {
      window.addEventListener('scroll', () => {
        if (window.pageYOffset > 300) {
          backToTop.classList.add('show');
        } else {
          backToTop.classList.remove('show');
        }
      });

      backToTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // Reading Progress Bar
    const progressBar = document.getElementById('readingProgress');
    if (progressBar) {
      window.addEventListener('scroll', () => {
        const windowHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (window.pageYOffset / windowHeight) * 100;
        progressBar.style.width = scrolled + '%';
      });
    }

    // Share content using Web Share API
    function shareContent() {
      const shareData = {
        title: 'Waseem | English Teacher & Full-Stack SEO Developer',
        text: "Check out Waseem's SEO & GEO portfolio!",
        url: window.location.href
      };

      if (navigator.share) {
        navigator.share(shareData).catch(() => {
          // Fallback to copy if share fails or is canceled
          copyToClipboard(window.location.href);
        });
      } else {
        // Fallback for browsers that don't support Web Share API
        copyToClipboard(window.location.href);
      }
    }

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text);
      const shareBtn = document.getElementById('shareBtn');
      if (shareBtn) {
        shareBtn.textContent = '✓ Copied!';
        setTimeout(() => {
          shareBtn.textContent = '📤 Share';
        }, 2000);
      }
    }

  </script>
</body>
</html>
